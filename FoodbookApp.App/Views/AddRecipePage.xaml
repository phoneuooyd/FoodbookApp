<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Foodbook.Services;assembly=FoodbookApp.App"
             xmlns:models="clr-namespace:Foodbook.Models;assembly=FoodbookApp.App"
             xmlns:vm="clr-namespace:Foodbook.ViewModels;assembly=FoodbookApp.App"
             xmlns:converters="clr-namespace:Foodbook.Converters;assembly=FoodbookApp.App"
             xmlns:resources="clr-namespace:FoodbookApp.Localization;assembly=FoodbookApp.App"
             xmlns:controls="clr-namespace:Foodbook.Views.Components;assembly=FoodbookApp.App"
             x:Class="Foodbook.Views.AddRecipePage"
             x:Name="ThisPage"
             x:DataType="vm:AddRecipeViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False"
             HideSoftInputOnTapped="True"
             BackgroundColor="{DynamicResource PageBackgroundColor}">
    <ContentPage.Resources>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
        <converters:StringToBoolConverter x:Key="StringToBoolConverter" />
        <converters:UnitToLocalizedStringConverter x:Key="UnitToStringConverter" />
        <converters:LabelSelectionToBorderConverter x:Key="LabelSelectionToBorderConverter" />

        <Style x:Key="OverhaulCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{DynamicResource OverhaulCardBackgroundColor}" />
            <Setter Property="Stroke" Value="{DynamicResource OverhaulCardStrokeColor}" />
            <Setter Property="StrokeThickness" Value="1.5" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="StrokeShape" Value="RoundRectangle 18" />
        </Style>

        <Style x:Key="SectionCaption" TargetType="Label">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="CharacterSpacing" Value="1.3" />
            <Setter Property="TextColor" Value="{DynamicResource OverhaulSectionCaptionColor}" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">
        <Grid Grid.Row="0" Background="{DynamicResource AppHeroGradientBrush}" Padding="18,50,18,20">
            <Border WidthRequest="120" HeightRequest="120" HorizontalOptions="End" VerticalOptions="Start" TranslationX="20" TranslationY="-34" BackgroundColor="{DynamicResource AppHeroBubbleColorStrong}" StrokeThickness="0" StrokeShape="RoundRectangle 60" />
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" ZIndex="2">
                <Border WidthRequest="34" HeightRequest="34" BackgroundColor="{DynamicResource AppHeroActionOverlayColor}" StrokeThickness="0" StrokeShape="RoundRectangle 17" VerticalOptions="Start">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CancelCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="‹" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="{Binding Title}" FontSize="26" FontAttributes="Bold" TextColor="White" />
                    <Label Text="{loc:Translate Resource=AddRecipePageResources, Key=BasicInfoHeader}" FontSize="13" TextColor="{DynamicResource AppHeroSubtitleTextColor}" />
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <controls:TabComponent x:Name="ContentHost" Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" SelectTabCommand="{Binding SelectTabCommand}" TabSize="Small">
            <controls:TabComponent.Tabs>
                <controls:TabItem Name="{loc:Translate Resource=AddRecipePageResources, Key=BasicInfoTab}">
                    <controls:TabItem.Content>
                        <ScrollView>
                            <VerticalStackLayout Padding="16" Spacing="10">
                                <Label Text="{loc:Translate Resource=AddRecipePageResources, Key=ModeSelection}" Style="{StaticResource SectionCaption}" />
                                <controls:SegmentedPickerComponent
                                    Option1Text="{loc:Translate Resource=AddRecipePageResources, Key=Manual}"
                                    Option1Command="{Binding SetManualModeCommand}"
                                    IsOption1Selected="{Binding IsManualMode}"
                                    Option2Text="{loc:Translate Resource=AddRecipePageResources, Key=FromLink}"
                                    Option2Command="{Binding SetImportModeCommand}"
                                    IsOption2Selected="{Binding IsImportMode}"
                                    ShowOption3="False" />

                                <VerticalStackLayout IsVisible="{Binding IsImportMode}" Spacing="8">
                                    <Label Text="{loc:Translate Resource=AddRecipePageResources, Key=ImportHeader}" Style="{StaticResource SectionCaption}" />

                                    <Border Style="{StaticResource OverhaulCard}" Padding="0">
                                        <VerticalStackLayout Spacing="0">
                                            <Grid Padding="14,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" IsVisible="{Binding CanUseAutoServingRecognition}">
                                                <Border WidthRequest="38" HeightRequest="38" BackgroundColor="{DynamicResource SegmentedContainerColor}" StrokeThickness="0" StrokeShape="RoundRectangle 10" VerticalOptions="Center">
                                                    <Label Text="🔎" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                                                </Border>
                                                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                                    <Label Text="czy rozpoznawać ilość porcji" FontSize="15" FontAttributes="Bold" TextColor="{DynamicResource FrameTextColor}" />
                                                    <Label Text="Import nie jest idealny przez różnorodność stylów stron WWW." FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                                                </VerticalStackLayout>
                                                <Switch Grid.Column="2"
                                                        VerticalOptions="Center"
                                                        IsToggled="{Binding IsAutoServingRecognitionEnabled}"
                                                        IsEnabled="{Binding CanUseAutoServingRecognition}"
                                                        OnColor="{DynamicResource Primary}" />
                                            </Grid>

                                            <BoxView HeightRequest="1" BackgroundColor="{DynamicResource DashboardCardStrokeColor}" IsVisible="{Binding CanUseAutoServingRecognition}" />

                                            <Grid Padding="14,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                <Border WidthRequest="38" HeightRequest="38" BackgroundColor="{DynamicResource SegmentedContainerColor}" StrokeThickness="0" StrokeShape="RoundRectangle 10" VerticalOptions="Center">
                                                    <Label Text="2️⃣" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                                                </Border>
                                                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                                    <Label Text="wpisz ilość porcji" FontSize="15" FontAttributes="Bold" TextColor="{DynamicResource FrameTextColor}" />
                                                    <Label Text="Ta wartość przeliczy składniki i kalorie do jednej porcji." FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                                                </VerticalStackLayout>
                                                <Switch Grid.Column="2"
                                                        VerticalOptions="Center"
                                                        IsToggled="{Binding IsManualServingCountEnabled}"
                                                        OnColor="{DynamicResource Primary}" />
                                            </Grid>

                                            <Border Style="{StaticResource ModernBorder}" Margin="14,0,14,14" IsVisible="{Binding IsManualServingCountEnabled}">
                                                <Entry Placeholder="2" Keyboard="Numeric" Text="{Binding ImportServingsCount}" HorizontalTextAlignment="Center" Focused="OnInputFocused" Unfocused="OnInputUnfocused" Style="{StaticResource ModernEntry}" />
                                            </Border>
                                        </VerticalStackLayout>
                                    </Border>

                                    <Border Style="{StaticResource OverhaulCard}">
                                        <VerticalStackLayout Spacing="6">
                                            <Label Text="{loc:Translate Resource=AddRecipePageResources, Key=UrlLabel}" Style="{StaticResource FieldLabel}" />
                                            <Entry Placeholder="{loc:Translate Resource=AddRecipePageResources, Key=UrlPlaceholder}" Text="{Binding ImportUrl}" Keyboard="Url" Focused="OnInputFocused" Unfocused="OnInputUnfocused" Style="{StaticResource ModernEntry}" />
                                        </VerticalStackLayout>
                                    </Border>
                                    <Button Command="{Binding ImportRecipeCommand}" Text="{loc:Translate Resource=AddRecipePageResources, Key=ImportButton}" HeightRequest="44" CornerRadius="12" BackgroundColor="{DynamicResource Primary}" TextColor="{DynamicResource ButtonPrimaryText}" />
                                    <Label Text="{Binding ImportStatus}" IsVisible="{Binding ImportStatus, Converter={StaticResource StringToBoolConverter}}" FontSize="12" TextColor="{DynamicResource SecondaryText}" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>

                                <VerticalStackLayout IsVisible="{Binding IsManualMode}" Spacing="8">
                                    <Label Text="{loc:Translate Resource=AddRecipePageResources, Key=BasicInfoHeader}" Style="{StaticResource SectionCaption}" />
                                    <Border Style="{StaticResource OverhaulCard}">
                                        <VerticalStackLayout Spacing="6">
                                            <Label Text="{loc:Translate Resource=AddRecipePageResources, Key=NameLabel}" Style="{StaticResource FieldLabel}" />
                                            <Entry Placeholder="{loc:Translate Resource=AddRecipePageResources, Key=NamePlaceholder}" Text="{Binding Name}" Focused="OnInputFocused" Unfocused="OnInputUnfocused" Style="{StaticResource ModernEntry}" />
                                        </VerticalStackLayout>
                                    </Border>
                                    <Border Style="{StaticResource OverhaulCard}">
                                        <VerticalStackLayout Spacing="6">
                                            <Label Text="{loc:Translate Resource=AddRecipePageResources, Key=DescriptionLabel}" Style="{StaticResource FieldLabel}" />
                                            <Editor Placeholder="{loc:Translate Resource=AddRecipePageResources, Key=DescriptionPlaceholder}" Text="{Binding Description}" Focused="OnInputFocused" Unfocused="OnInputUnfocused" AutoSize="TextChanges" MinimumHeightRequest="120" BackgroundColor="Transparent" TextColor="{DynamicResource FrameTextColor}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </ScrollView>
                    </controls:TabItem.Content>
                </controls:TabItem>

                <controls:TabItem Name="{loc:Translate Resource=AddRecipePageResources, Key=IngredientsTab}">
                    <controls:TabItem.Content>
                        <ScrollView>
                            <VerticalStackLayout Padding="16" Spacing="10">
                                <Label Text="{loc:Translate Resource=AddRecipePageResources, Key=IngredientsHeader}" Style="{StaticResource SectionCaption}" />
                                <CollectionView ItemsSource="{Binding Ingredients}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:Ingredient">
                                            <Grid RowDefinitions="Auto,Auto,Auto">
                                                <BoxView Grid.Row="0" HeightRequest="4" BackgroundColor="{DynamicResource Primary}" Opacity="0">
                                                    <BoxView.GestureRecognizers>
                                                        <DropGestureRecognizer AllowDrop="True" DragOver="OnIngredientTopInsertDragOver" DragLeave="OnIngredientTopInsertDragLeave" Drop="OnIngredientTopInsertDrop" />
                                                    </BoxView.GestureRecognizers>
                                                    <BoxView.Triggers>
                                                        <DataTrigger TargetType="BoxView" Binding="{Binding ShowInsertBefore}" Value="True"><Setter Property="Opacity" Value="0.6" /></DataTrigger>
                                                    </BoxView.Triggers>
                                                </BoxView>

                                                <Border Grid.Row="1" Style="{StaticResource OverhaulCard}" Margin="0,3">
                                                    <Border.GestureRecognizers>
                                                        <DragGestureRecognizer CanDrag="True" DragStarting="OnIngredientDragStarting" />
                                                    </Border.GestureRecognizers>
                                                    <Grid ColumnDefinitions="2*,*,Auto,Auto" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="8">
                                                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="3">
                                                            <Label Text="{loc:Translate Resource=AddRecipePageResources, Key=IngredientLabel}" Style="{StaticResource FieldLabel}" />
                                                            <controls:SearchablePickerComponent PlaceholderText="{loc:Translate Resource=AddRecipePageResources, Key=SelectIngredientPlaceholder}" ItemsSource="{Binding BindingContext.AvailableIngredientNames, Source={x:Reference ThisPage}}" SelectedItem="{Binding Name}" SelectionChanged="OnIngredientNameChanged" />
                                                        </VerticalStackLayout>
                                                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="3">
                                                            <Label Text="{loc:Translate Resource=AddRecipePageResources, Key=QuantityLabelShort}" Style="{StaticResource FieldLabel}" />
                                                            <Border Style="{StaticResource ModernBorder}">
                                                                <Entry Placeholder="100" Keyboard="Numeric" Text="{Binding Quantity}" HorizontalTextAlignment="Center" Focused="OnInputFocused" Unfocused="OnInputUnfocused" TextChanged="OnIngredientValueChanged" Style="{StaticResource ModernEntry}" />
                                                            </Border>
                                                        </VerticalStackLayout>
                                                        <VerticalStackLayout Grid.Row="0" Grid.Column="2" Spacing="3">
                                                            <Label Text="{loc:Translate Resource=AddRecipePageResources, Key=UnitLabelShort}" Style="{StaticResource FieldLabel}" />
                                                            <controls:SimplePicker ItemsSource="{Binding BindingContext.Units, Source={x:Reference ThisPage}}" SelectedItem="{Binding Unit}" ItemDisplayBinding="{Binding Converter={StaticResource UnitToStringConverter}}" Title="Jednostka" />
                                                        </VerticalStackLayout>
                                                        <Button Grid.Row="0" Grid.Column="3" Style="{StaticResource DeleteButton}" Command="{Binding BindingContext.RemoveIngredientCommand, Source={x:Reference ThisPage}}" CommandParameter="{Binding .}" VerticalOptions="End" HorizontalOptions="Center" />

                                                        <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="4" Spacing="12" Margin="0,6,0,0">
                                                            <Label Text="{Binding DisplayCalories, StringFormat='🔥 {0:F1} kcal'}" FontSize="11" TextColor="{DynamicResource SecondaryText}" />
                                                            <Label Text="{Binding DisplayProtein, StringFormat='💪 {0:F1}g'}" FontSize="11" TextColor="{DynamicResource SecondaryText}" />
                                                            <Label Text="{Binding DisplayFat, StringFormat='🧈 {0:F1}g'}" FontSize="11" TextColor="{DynamicResource SecondaryText}" />
                                                            <Label Text="{Binding DisplayCarbs, StringFormat='🌾 {0:F1}g'}" FontSize="11" TextColor="{DynamicResource SecondaryText}" />
                                                        </HorizontalStackLayout>
                                                    </Grid>
                                                </Border>

                                                <BoxView Grid.Row="2" HeightRequest="4" BackgroundColor="{DynamicResource Primary}" Opacity="0">
                                                    <BoxView.GestureRecognizers>
                                                        <DropGestureRecognizer AllowDrop="True" DragOver="OnIngredientBottomInsertDragOver" DragLeave="OnIngredientBottomInsertDragLeave" Drop="OnIngredientBottomInsertDrop" />
                                                    </BoxView.GestureRecognizers>
                                                    <BoxView.Triggers>
                                                        <DataTrigger TargetType="BoxView" Binding="{Binding ShowInsertAfter}" Value="True"><Setter Property="Opacity" Value="0.6" /></DataTrigger>
                                                    </BoxView.Triggers>
                                                </BoxView>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                                <Button Command="{Binding AddIngredientCommand}" HeightRequest="46" CornerRadius="14" BackgroundColor="{DynamicResource OverhaulAccentSoftColor}" BorderColor="{DynamicResource Primary}" BorderWidth="1.5" TextColor="{DynamicResource FrameTextColor}" Text="{loc:Translate Resource=AddRecipePageResources, Key=AddIngredient}" />
                            </VerticalStackLayout>
                        </ScrollView>
                    </controls:TabItem.Content>
                </controls:TabItem>

                <controls:TabItem Name="{loc:Translate Resource=AddRecipePageResources, Key=NutritionTab}">
                    <controls:TabItem.Content>
                        <ScrollView>
                            <VerticalStackLayout Padding="16" Spacing="10">
                                <Label Text="{loc:Translate Resource=AddRecipePageResources, Key=CalcModeLabel}" Style="{StaticResource SectionCaption}" />
                                <Border Style="{StaticResource OverhaulCard}" Padding="6">
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                        <Button Grid.Column="0" BackgroundColor="{Binding UseCalculatedValues, Converter={StaticResource BoolToColorConverter}, ConverterParameter=SegmentSelectedBg}" TextColor="{Binding UseCalculatedValues, Converter={StaticResource BoolToColorConverter}, ConverterParameter=SegmentText}" HeightRequest="40" CornerRadius="10" Clicked="OnAutoModeClicked" Text="{loc:Translate Resource=AddRecipePageResources, Key=AutoButton}" />
                                        <Button Grid.Column="1" BackgroundColor="{Binding UseManualValues, Converter={StaticResource BoolToColorConverter}, ConverterParameter=SegmentSelectedBg}" TextColor="{Binding UseManualValues, Converter={StaticResource BoolToColorConverter}, ConverterParameter=SegmentText}" HeightRequest="40" CornerRadius="10" Clicked="OnManualModeClicked" Text="{loc:Translate Resource=AddRecipePageResources, Key=ManualButton}" />
                                    </Grid>
                                </Border>

                                <VerticalStackLayout IsVisible="{Binding UseCalculatedValues}" Spacing="8">
                                    <Label Text="{loc:Translate Resource=AddRecipePageResources, Key=AutoCalculatedInfo}" FontSize="12" TextColor="{DynamicResource SecondaryText}" HorizontalTextAlignment="Center" />
                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource OverhaulCard}"><VerticalStackLayout Spacing="4"><Label Text="{loc:Translate Resource=AddRecipePageResources, Key=CaloriesLabel}" Style="{StaticResource FieldLabel}" /><Label Text="{Binding CalculatedCalories}" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="{DynamicResource FrameTextColor}" /></VerticalStackLayout></Border>
                                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource OverhaulCard}"><VerticalStackLayout Spacing="4"><Label Text="{loc:Translate Resource=AddRecipePageResources, Key=ProteinLabel}" Style="{StaticResource FieldLabel}" /><Label Text="{Binding CalculatedProtein}" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="{DynamicResource FrameTextColor}" /></VerticalStackLayout></Border>
                                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource OverhaulCard}"><VerticalStackLayout Spacing="4"><Label Text="{loc:Translate Resource=AddRecipePageResources, Key=FatLabel}" Style="{StaticResource FieldLabel}" /><Label Text="{Binding CalculatedFat}" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="{DynamicResource FrameTextColor}" /></VerticalStackLayout></Border>
                                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource OverhaulCard}"><VerticalStackLayout Spacing="4"><Label Text="{loc:Translate Resource=AddRecipePageResources, Key=CarbsLabel}" Style="{StaticResource FieldLabel}" /><Label Text="{Binding CalculatedCarbs}" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="{DynamicResource FrameTextColor}" /></VerticalStackLayout></Border>
                                    </Grid>
                                </VerticalStackLayout>

                                <VerticalStackLayout IsVisible="{Binding UseManualValues}" Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Label Grid.Column="0" Text="{loc:Translate Resource=AddRecipePageResources, Key=ManualInputLabel}" FontSize="12" TextColor="{DynamicResource SecondaryText}" VerticalOptions="Center" />
                                        <Button Grid.Column="1" Command="{Binding CopyCalculatedValuesCommand}" Text="{loc:Translate Resource=AddRecipePageResources, Key=CopyCalculated}" HeightRequest="32" CornerRadius="8" BackgroundColor="{DynamicResource Primary}" TextColor="{DynamicResource ButtonPrimaryText}" FontSize="12" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource OverhaulCard}"><VerticalStackLayout Spacing="6"><Label Text="{loc:Translate Resource=AddRecipePageResources, Key=CaloriesLabel}" Style="{StaticResource FieldLabel}" /><Entry Placeholder="0.0" Keyboard="Numeric" Text="{Binding Calories}" Focused="OnInputFocused" Unfocused="OnInputUnfocused" Style="{StaticResource ModernEntry}" /></VerticalStackLayout></Border>
                                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource OverhaulCard}"><VerticalStackLayout Spacing="6"><Label Text="{loc:Translate Resource=AddRecipePageResources, Key=ProteinLabel}" Style="{StaticResource FieldLabel}" /><Entry Placeholder="0.0" Keyboard="Numeric" Text="{Binding Protein}" Focused="OnInputFocused" Unfocused="OnInputUnfocused" Style="{StaticResource ModernEntry}" /></VerticalStackLayout></Border>
                                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource OverhaulCard}"><VerticalStackLayout Spacing="6"><Label Text="{loc:Translate Resource=AddRecipePageResources, Key=FatLabel}" Style="{StaticResource FieldLabel}" /><Entry Placeholder="0.0" Keyboard="Numeric" Text="{Binding Fat}" Focused="OnInputFocused" Unfocused="OnInputUnfocused" Style="{StaticResource ModernEntry}" /></VerticalStackLayout></Border>
                                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource OverhaulCard}"><VerticalStackLayout Spacing="6"><Label Text="{loc:Translate Resource=AddRecipePageResources, Key=CarbsLabel}" Style="{StaticResource FieldLabel}" /><Entry Placeholder="0.0" Keyboard="Numeric" Text="{Binding Carbs}" Focused="OnInputFocused" Unfocused="OnInputUnfocused" Style="{StaticResource ModernEntry}" /></VerticalStackLayout></Border>
                                    </Grid>
                                </VerticalStackLayout>

                                <Label Text="{Binding ValidationMessage}" IsVisible="{Binding HasValidationError}" FontSize="12" TextColor="#F43F5E" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </ScrollView>
                    </controls:TabItem.Content>
                </controls:TabItem>
            </controls:TabComponent.Tabs>
        </controls:TabComponent>

        <Grid Grid.Row="2" Padding="16,10,16,16" ColumnDefinitions="Auto,*" ColumnSpacing="10" BackgroundColor="{DynamicResource OverhaulFooterSurfaceColor}">
            <Button Grid.Column="0" Command="{Binding CancelCommand}" Text="{x:Static resources:ButtonResources.Cancel}" HeightRequest="48" CornerRadius="12" Padding="18,0" BackgroundColor="Transparent" BorderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" BorderWidth="1.5" TextColor="{DynamicResource FrameTextColor}" />
            <Button Grid.Column="1" Command="{Binding SaveRecipeCommand}" Text="{Binding SaveButtonText}" HeightRequest="48" CornerRadius="12" BackgroundColor="{DynamicResource Primary}" TextColor="{DynamicResource ButtonPrimaryText}" />
        </Grid>
    </Grid>
</ContentPage>
