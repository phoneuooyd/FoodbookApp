<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Foodbook.Services"
             xmlns:vm="clr-namespace:Foodbook.ViewModels"
             xmlns:converters="clr-namespace:Foodbook.Converters"
             xmlns:components="clr-namespace:Foodbook.Views.Components"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:resources="clr-namespace:FoodbookApp.Localization"
             x:Class="Foodbook.Views.RecipesPage"
             x:Name="ThisPage"
             x:DataType="vm:RecipeViewModel"
             Title="{loc:Translate Resource=RecipesPageResources, Key=Title}"
             BackgroundColor="{DynamicResource PageBackgroundColor}"
             Shell.NavBarIsVisible="false">
    <ContentPage.Resources>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />

        <LinearGradientBrush x:Key="HeroGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{DynamicResource Primary}" Offset="0.0" />
            <GradientStop Color="{DynamicResource Tertiary}" Offset="1.0" />
        </LinearGradientBrush>

        <Style x:Key="HeroEyebrowStyle" TargetType="Label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="#C7BCFF" />
        </Style>

        <Style x:Key="HeroTitleStyle" TargetType="Label">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="White" />
        </Style>

        <DataTemplate x:Key="RecipeItemTemplate">
            <components:UniversalListItemComponent 
                EditCommand="{Binding BindingContext.EditItemCommand, Source={x:Reference ThisPage}}"
                DeleteCommand="{Binding BindingContext.DeleteItemCommand, Source={x:Reference ThisPage}}"
                FolderEditCommand="{Binding BindingContext.FolderEditCommand, Source={x:Reference ThisPage}}"
                ShowSubtitle="False"
                ShowNutritionLayout="True"
                ShowPlanLayout="False"
                ShowDeleteButton="True"
                ShowArchiveButton="False"
                ShowDragAndDrop="True"
                DragStartingCommand="{Binding BindingContext.DragStartingCommand, Source={x:Reference ThisPage}}"
                DragOverCommand="{Binding BindingContext.DragOverCommand, Source={x:Reference ThisPage}}"
                DragLeaveCommand="{Binding BindingContext.DragLeaveCommand, Source={x:Reference ThisPage}}"
                DropCommand="{Binding BindingContext.DropCommand, Source={x:Reference ThisPage}}" />
        </DataTemplate>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*">

        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto"
              Background="{StaticResource HeroGradientBrush}">
            <Border WidthRequest="108"
                    HeightRequest="108"
                    StrokeThickness="0"
                    Stroke="Transparent"
                    BackgroundColor="#14FFFFFF"
                    StrokeShape="RoundRectangle 54"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,-28,-20,0" />
            <Border WidthRequest="76"
                    HeightRequest="76"
                    StrokeThickness="0"
                    Stroke="Transparent"
                    BackgroundColor="#10FFFFFF"
                    StrokeShape="RoundRectangle 38"
                    HorizontalOptions="Start"
                    VerticalOptions="End"
                    Margin="-12,0,0,14" />

            <VerticalStackLayout Padding="20,18,20,6"
                                 Spacing="0"
                                 ZIndex="1">
                <Label Text="{loc:Translate Resource=RecipesPageResources, Key=Title}"
                       Style="{StaticResource HeroTitleStyle}" />
            </VerticalStackLayout>

            <Grid Grid.Row="1"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="8"
                  Padding="0,0,12,12"
                  VerticalOptions="End"
                  ZIndex="1">
                <components:ModernSearchBarComponent Grid.Column="0"
                                                     SearchText="{Binding SearchText}"
                                                     PlaceholderText="{loc:Translate Resource=RecipesPageResources, Key=SearchPlaceholder}"
                                                     ClearCommand="{Binding ClearSearchCommand}"
                                                     IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" />
                <Border Grid.Column="1"
                        WidthRequest="44"
                        HeightRequest="44"
                        Margin="0,10,0,10"
                        StrokeThickness="0"
                        Stroke="Transparent"
                        BackgroundColor="#22FFFFFF"
                        StrokeShape="RoundRectangle 14"
                        HorizontalOptions="End"
                        VerticalOptions="Center">
                    <ImageButton Grid.Column="1"
                                 x:Name="FilterButton"
                                 WidthRequest="28"
                                 HeightRequest="28"
                                 BackgroundColor="Transparent"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Source="Resources/Images/filter.png"
                                 Clicked="OnFilterSortClicked"
                                 AutomationId="RecipesFilterButton">
                        <ImageButton.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="White" />
                        </ImageButton.Behaviors>
                    </ImageButton>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,*"
              Padding="12,8"
              BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}">
            <Grid.GestureRecognizers>
                <DropGestureRecognizer AllowDrop="True" Drop="OnBreadcrumbDrop" />
            </Grid.GestureRecognizers>

            <Border StrokeThickness="0"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="{DynamicResource Secondary}"
                    Padding="0"
                    WidthRequest="36"
                    HeightRequest="32"
                    VerticalOptions="Center">
                <Button x:Name="BackButton"
                        Text="◀"
                        Command="{Binding GoBackCommand}"
                        IsEnabled="{Binding CanGoBack}"
                        BackgroundColor="Transparent"
                        TextColor="{DynamicResource Primary}"
                        WidthRequest="36"
                        HeightRequest="32"
                        Padding="0"
                        Margin="0" />
            </Border>

            <Label Grid.Column="1"
                   Text="{Binding CurrentPathDisplay}"
                   Margin="10,0,0,0"
                   FontSize="13"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource PrimaryText}"
                   VerticalTextAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="2">
            <components:GenericListComponent x:Name="ListComponent"
                ItemsSource="{Binding Items}"
                ItemTemplate="{StaticResource RecipeItemTemplate}"
                EmptyTitle="{loc:Translate Resource=RecipesPageResources, Key=EmptyTitle}"
                EmptyHint="{loc:Translate Resource=RecipesPageResources, Key=EmptyHint}"
                IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" />

            <components:FloatingActionButtonComponent x:Name="RecipesFab"
                IsExpandable="True"
                IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                ButtonText="+">
                <components:FloatingActionButtonComponent.Actions>
                    <components:FabActionItem Text="{loc:Translate Resource=RecipesPageResources, Key=AddRecipeAction}" Command="{Binding BindingContext.AddRecipeCommand, Source={x:Reference ThisPage}}" />
                    <components:FabActionItem Text="{loc:Translate Resource=RecipesPageResources, Key=AddFolderAction}" Command="{Binding BindingContext.AddFolderCommand, Source={x:Reference ThisPage}}" />
                </components:FloatingActionButtonComponent.Actions>
            </components:FloatingActionButtonComponent>
        </Grid>
    </Grid>

</ContentPage>