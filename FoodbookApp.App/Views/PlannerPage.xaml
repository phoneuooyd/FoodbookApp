<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Foodbook.Services"
             xmlns:models="clr-namespace:Foodbook.Models"
             xmlns:vm="clr-namespace:Foodbook.ViewModels"
             xmlns:converters="clr-namespace:Foodbook.Converters"
             xmlns:components="clr-namespace:Foodbook.Views.Components"
             xmlns:resources="clr-namespace:FoodbookApp.Localization"
             x:Class="Foodbook.Views.PlannerPage"
             x:Name="ThisPage"
             Title="{loc:Translate Resource=PlannerPageResources, Key=Title}"
             BackgroundColor="{DynamicResource PageBackgroundColor}">
    <ContentPage.Resources>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        <converters:RecipeSelectedToStrokeConverter x:Key="RecipeSelectedToStrokeConverter" />
        <converters:RecipeSelectedToStrokeThicknessConverter x:Key="RecipeSelectedToStrokeThicknessConverter" />
        <!-- Local styles to render cards using Border instead of deprecated Frame -->
        <Style x:Key="PlannerCardBorder" TargetType="Border">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BackgroundColor" Value="{DynamicResource FrameBackgroundColor}" />
            <Setter Property="Stroke" Value="{AppThemeBinding Light=LightGray, Dark=#555555}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeShape" Value="RoundRectangle 8" />
        </Style>
        <Style x:Key="PlannerDatePicker" TargetType="DatePicker">
            <Setter Property="TextColor" Value="{DynamicResource FrameTextColor}" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalOptions" Value="FillAndExpand" />
        </Style>
        <!-- Style for recipe picker border - with selected state -->
        <Style x:Key="RecipePickerBorder" TargetType="Border">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="StrokeShape" Value="RoundRectangle 8" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Stroke" Value="{AppThemeBinding Light=LightGray, Dark=#555555}" />
        </Style>
    </ContentPage.Resources>
    <Grid RowDefinitions="*">
        <!-- Loading -->
        <Grid Grid.Row="0" IsVisible="{Binding IsLoading}" VerticalOptions="Center" HorizontalOptions="Center" Padding="40" 
              RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="20">
            <ActivityIndicator Grid.Row="0" IsRunning="{Binding IsLoading}" Color="{DynamicResource Primary}" WidthRequest="60" HeightRequest="60" />
            <Label Grid.Row="1" Text="{Binding LoadingStatus}" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="{DynamicResource Primary}" />
            <ProgressBar Grid.Row="2" Progress="{Binding LoadingProgress}" ProgressColor="{DynamicResource Primary}" BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" HeightRequest="6" WidthRequest="300" HorizontalOptions="Center" />
            <Label Grid.Row="3" FontSize="14" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}">
                <Label.Text>
                    <MultiBinding StringFormat="{}{0:P0}">
                        <Binding Path="LoadingProgress" />
                    </MultiBinding>
                </Label.Text>
            </Label>
            <Label Grid.Row="4" FontSize="12" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" Margin="0,10,0,0" Text="{loc:Translate Resource=PlannerPageResources, Key=LoadingTip}" />
        </Grid>
        <!-- Content -->
        <ScrollView Grid.Row="0" IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
            <Grid Padding="10" RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="15">
                <!-- Row 0: Date pickers -->
                <Grid Grid.Row="0" ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,5">
                    <Grid Grid.Column="0" RowDefinitions="Auto,Auto" HorizontalOptions="Start">
                        <Label Grid.Row="0" Text="{loc:Translate Resource=PlannerPageResources, Key=DateFrom}" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource Primary}" Margin="0,0,0,5" />
                        <!-- Date From card -->
                        <Border Grid.Row="1" Style="{StaticResource PlannerCardBorder}">
                            <DatePicker x:Name="StartDatePicker" Date="{Binding StartDate}" Format="dd.MM.yyyy" Style="{StaticResource PlannerDatePicker}" />
                        </Border>
                    </Grid>
                    <Grid Grid.Column="1" RowDefinitions="Auto,Auto" HorizontalOptions="End">
                        <Label Grid.Row="0" Text="{loc:Translate Resource=PlannerPageResources, Key=DateTo}" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource Primary}" Margin="0,0,0,5" />
                        <!-- Date To card -->
                        <Border Grid.Row="1" Style="{StaticResource PlannerCardBorder}">
                            <DatePicker x:Name="EndDatePicker" Date="{Binding EndDate}" Format="dd.MM.yyyy" Style="{StaticResource PlannerDatePicker}" />
                        </Border>
                    </Grid>
                </Grid>

                <!-- Row 1: Meals per day card -->
                <Border Grid.Row="1" Style="{StaticResource PlannerCardBorder}" Margin="0,0,0,0">
                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="10" HorizontalOptions="Center">
                        <Label Grid.Column="0" Text="{loc:Translate Resource=PlannerPageResources, Key=MealsPerDay}" VerticalOptions="Center" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource Primary}" />
                        <Entry Grid.Column="1" Text="{Binding MealsPerDay}" Keyboard="Numeric" WidthRequest="50" FontSize="14" HorizontalTextAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Row 2: Days list -->
                <VerticalStackLayout Grid.Row="3" BindableLayout.ItemsSource="{Binding Days}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:PlannerDay">
                            <Border Stroke="LightGray"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="8"
                                    Margin="0,3"
                                    BackgroundColor="{DynamicResource FrameBackgroundColor}">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="0">
                                    <!-- Row 0: Date label -->
                                    <Label Grid.Row="0" 
                                           Text="{Binding DateLabel}" 
                                           FontAttributes="Bold" 
                                           FontSize="14" 
                                           TextColor="{DynamicResource FrameTextColor}" />

                                    <!-- Row 1: Meals list -->
                                    <StackLayout Grid.Row="1" BindableLayout.ItemsSource="{Binding Meals}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="models:PlannedMeal">
                                                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="4" Margin="0,1">
                                                    <!-- Recipe Picker wrapped in Border -->
                                                    <Border Grid.Column="0" 
                                                            x:Name="RecipeBorder"
                                                            Style="{StaticResource RecipePickerBorder}"
                                                            BackgroundColor="{DynamicResource FrameBackgroundColor}"
                                                            Stroke="{Binding Recipe, Converter={StaticResource RecipeSelectedToStrokeConverter}}"
                                                            StrokeThickness="{Binding Recipe, Converter={StaticResource RecipeSelectedToStrokeThicknessConverter}}">
                                                        <components:FolderAwarePickerComponent SelectedRecipe="{Binding Recipe}" 
                                                                                              PlaceholderText="{loc:Translate Resource=PlannerPageResources, Key=SelectRecipePlaceholder}" />
                                                    </Border>
                                                    <Button Grid.Column="1" Text="➖" Command="{Binding BindingContext.DecreasePortionsCommand, Source={x:Reference ThisPage}}" CommandParameter="{Binding .}"
                                                            WidthRequest="35" HeightRequest="35" MinimumWidthRequest="18" MinimumHeightRequest="18"
                                                            CornerRadius="9" FontSize="14" FontAttributes="Bold" BorderWidth="0" Padding="0"
                                                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" TextColor="{AppThemeBinding Light=Black, Dark=White}">
                                                        <Button.Triggers>
                                                            <DataTrigger TargetType="Button" Binding="{Binding Portions}" Value="1">
                                                                <Setter Property="IsEnabled" Value="False" />
                                                                <Setter Property="BackgroundColor" Value="LightGray" />
                                                            </DataTrigger>
                                                        </Button.Triggers>
                                                    </Button>
                                                    <Label Grid.Column="2" 
                                                           Text="{Binding Portions}" 
                                                           VerticalOptions="Center" 
                                                           HorizontalOptions="Center" 
                                                           FontSize="18" 
                                                           FontAttributes="Bold" 
                                                           TextColor="{DynamicResource FrameTextColor}" 
                                                           WidthRequest="36" 
                                                           HorizontalTextAlignment="Center" />
                                                    <Button Grid.Column="3" Text="➕" Command="{Binding BindingContext.IncreasePortionsCommand, Source={x:Reference ThisPage}}" CommandParameter="{Binding .}"
                                                            WidthRequest="35" HeightRequest="35" MinimumWidthRequest="18" MinimumHeightRequest="18"
                                                            CornerRadius="9" FontSize="14" FontAttributes="Bold" BorderWidth="0" Padding="0"
                                                            BackgroundColor="{DynamicResource Primary}" TextColor="{DynamicResource ButtonPrimaryText}">
                                                        <Button.Triggers>
                                                            <DataTrigger TargetType="Button" Binding="{Binding Portions}" Value="20">
                                                                <Setter Property="IsEnabled" Value="False" />
                                                                <Setter Property="BackgroundColor" Value="LightGray" />
                                                            </DataTrigger>
                                                        </Button.Triggers>
                                                    </Button>
                                                    <Button Grid.Column="4" Text="✕"  Command="{Binding BindingContext.RemoveMealCommand, Source={x:Reference ThisPage}}" CommandParameter="{Binding .}" MinimumWidthRequest="18" MinimumHeightRequest="18" WidthRequest="35" HeightRequest="35" BackgroundColor="{AppThemeBinding Light=#FFE6E6, Dark=#4A2C2C}" TextColor="{AppThemeBinding Light=#CC0000, Dark=#FF6666}" FontSize="14" CornerRadius="9" BorderColor="{AppThemeBinding Light=#FFCCCC, Dark=#664444}" BorderWidth="1" Padding="0" />
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>

                                    <!-- Row 2: Nutritional summary for the day - Grid with Auto columns -->
                                    <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="15" Margin="0,8,0,4">
                                        <Label Grid.Column="0" Text="{Binding TotalCalories, StringFormat='⚡ {0:F1} kcal'}" FontSize="11" TextColor="Gray" />
                                        <Label Grid.Column="1" Text="{Binding TotalProtein, StringFormat='🥩 {0:F1}g'}" FontSize="11" TextColor="Gray" />
                                        <Label Grid.Column="2" Text="{Binding TotalFat, StringFormat='🧈 {0:F1}g'}" FontSize="11" TextColor="Gray" />
                                        <Label Grid.Column="3" Text="{Binding TotalCarbs, StringFormat='🌾 {0:F1}g'}" FontSize="11" TextColor="Gray" />
                                    </Grid>

                                    <!-- Row 3: Add meal button -->
                                    <Button Grid.Row="3" 
                                            Command="{Binding BindingContext.AddMealCommand, Source={x:Reference ThisPage}}" 
                                            CommandParameter="{Binding .}" 
                                            StyleClass="Secondary"
                                            FontSize="12" 
                                            FontAttributes="Bold" 
                                            CornerRadius="6" 
                                            Padding="12,6" 
                                            WidthRequest="120" 
                                            HeightRequest="32"
                                            HorizontalOptions="Center"
                                            Margin="0,4,0,0"
                                            Text="{loc:Translate Resource=PlannerPageResources, Key=AddMeal}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- Row 3: Save button -->
                <Grid Grid.Row="4" Padding="20,10" BackgroundColor="{DynamicResource PageBackgroundColor}">
                    <Button Command="{Binding SaveCommand}" 
                            StyleClass="Primary"
                            HeightRequest="50" 
                            HorizontalOptions="FillAndExpand">
                        <Button.ImageSource>
                            <FileImageSource File="save.png" />
                        </Button.ImageSource>
                    </Button>
                </Grid>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>