<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Foodbook.Services"
             xmlns:vm="clr-namespace:Foodbook.ViewModels"
             x:Class="Foodbook.Views.SetupPlanSelectionPage"
             x:DataType="vm:SetupWizardViewModel">

    <VerticalStackLayout Spacing="16">
        <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=PlanSectionTitle}"
               FontSize="20"
               FontAttributes="Bold"
               TextColor="{DynamicResource Primary}" />

        <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=PlanSectionDescription}"
               FontSize="14"
               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />

        <Label IsVisible="{Binding IsGuestMode}"
               Text="{loc:Translate Resource=SetupWizardPageResources, Key=GuestPlanLockedInfo}"
               FontSize="13"
               TextColor="{DynamicResource Primary}" />

        <Frame BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}"
               BorderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
               CornerRadius="10"
               Padding="16">
            <Frame.Triggers>
                <DataTrigger TargetType="Frame"
                             Binding="{Binding IsFreePlanSelected}"
                             Value="True">
                    <Setter Property="BorderColor" Value="{DynamicResource Primary}" />
                </DataTrigger>
            </Frame.Triggers>
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Label Grid.Column="0"
                           Text="{loc:Translate Resource=SetupWizardPageResources, Key=FreePlanTitle}"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <Label Grid.Column="1"
                           Text="✓"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{DynamicResource Primary}"
                           IsVisible="{Binding IsFreePlanSelected}" />
                </Grid>

                <BoxView HeightRequest="3"
                         CornerRadius="2"
                         Color="{DynamicResource Primary}"
                         IsVisible="{Binding IsFreePlanSelected}" />

                <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=FreePlanDescription}"
                       FontSize="13" />
                <Button Text="{loc:Translate Resource=SetupWizardPageResources, Key=ChooseFreePlanButton}"
                        Command="{Binding SelectFreePlanCommand}"
                        TextColor="{DynamicResource ButtonPrimaryText}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsFreePlanSelected}"
                                     Value="True">
                            <Setter Property="BackgroundColor" Value="{DynamicResource Tertiary}" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsFreePlanSelected}"
                                     Value="False">
                            <Setter Property="BackgroundColor" Value="{DynamicResource Secondary}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </VerticalStackLayout>
        </Frame>

        <Frame BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}"
               BorderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
               CornerRadius="10"
               Padding="16">
            <Frame.Triggers>
                <DataTrigger TargetType="Frame"
                             Binding="{Binding IsPremiumPlanSelected}"
                             Value="True">
                    <Setter Property="BorderColor" Value="{DynamicResource Primary}" />
                </DataTrigger>
                <DataTrigger TargetType="Frame"
                             Binding="{Binding CanSelectPremiumPlan}"
                             Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}" />
                </DataTrigger>
            </Frame.Triggers>
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Label Grid.Column="0"
                           Text="{loc:Translate Resource=SetupWizardPageResources, Key=PremiumPlanTitle}"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <Label Grid.Column="1"
                           Text="✓"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{DynamicResource Primary}"
                           IsVisible="{Binding IsPremiumPlanSelected}" />
                </Grid>

                <BoxView HeightRequest="3"
                         CornerRadius="2"
                         Color="{DynamicResource Primary}"
                         IsVisible="{Binding IsPremiumPlanSelected}" />

                <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=PremiumPlanDescription}"
                       FontSize="13" />
                <Button Text="{loc:Translate Resource=SetupWizardPageResources, Key=ChoosePremiumPlanButton}"
                        Command="{Binding SelectPremiumPlanCommand}"
                        IsEnabled="{Binding CanSelectPremiumPlan}"
                        TextColor="{DynamicResource ButtonPrimaryText}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsPremiumPlanSelected}"
                                     Value="True">
                            <Setter Property="BackgroundColor" Value="{DynamicResource Tertiary}" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsPremiumPlanSelected}"
                                     Value="False">
                            <Setter Property="BackgroundColor" Value="{DynamicResource Secondary}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </VerticalStackLayout>
        </Frame>
    </VerticalStackLayout>
</ContentView>
