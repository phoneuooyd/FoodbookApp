<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Foodbook.Services"
             xmlns:vm="clr-namespace:Foodbook.ViewModels"
             x:Class="Foodbook.Views.SetupPlanSelectionPage"
             x:DataType="vm:SetupWizardViewModel">

    <VerticalStackLayout Spacing="12">
        <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=PlanSectionTitle}"
               FontSize="20"
               FontAttributes="Bold"
               TextColor="{DynamicResource Primary}" />

        <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=PlanSectionDescription}"
               FontSize="14"
               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />

        <Label IsVisible="{Binding IsGuestMode}"
               Text="{loc:Translate Resource=SetupWizardPageResources, Key=GuestPlanLockedInfo}"
               FontSize="13"
               TextColor="{DynamicResource Primary}" />

        <Frame CornerRadius="18"
               Padding="16"
               HasShadow="False"
               BorderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
               BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}">
            <Frame.Triggers>
                <DataTrigger TargetType="Frame" Binding="{Binding IsFreePlanSelected}" Value="True">
                    <Setter Property="BorderColor" Value="{DynamicResource Primary}" />
                    <Setter Property="BackgroundColor" Value="{DynamicResource SelectionAccentStrongBackgroundColor}" />
                    <Setter Property="HasShadow" Value="True" />
                </DataTrigger>
            </Frame.Triggers>
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Label Grid.Column="0" Text="{loc:Translate Resource=SetupWizardPageResources, Key=FreePlanTitle}" FontSize="20" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{loc:Translate Resource=SetupWizardPageResources, Key=FreePlanBadge}" FontSize="11" Padding="10,4" BackgroundColor="{DynamicResource BadgeNeutralBackgroundColor}" TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" />
                </Grid>

                <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=FreePlanPrice}" FontSize="22" FontAttributes="Bold" />

                <VerticalStackLayout Spacing="4">
                    <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=FreeFeature1}" FontSize="13" />
                    <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=FreeFeature2}" FontSize="13" />
                    <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=FreeFeature3}" FontSize="13" />
                    <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=FreeFeature4}" FontSize="13" />
                </VerticalStackLayout>

                <Button Text="{loc:Translate Resource=SetupWizardPageResources, Key=ChooseFreePlanButton}"
                        Command="{Binding SelectFreePlanCommand}"
                        TextColor="{DynamicResource ButtonPrimaryText}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsFreePlanSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button" Binding="{Binding IsFreePlanSelected}" Value="False">
                            <Setter Property="BackgroundColor" Value="{DynamicResource Secondary}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </VerticalStackLayout>
        </Frame>

        <Frame CornerRadius="18"
               Padding="16"
               HasShadow="False"
               BorderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
               BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}">
            <Frame.Triggers>
                <DataTrigger TargetType="Frame" Binding="{Binding IsPremiumPlanSelected}" Value="True">
                    <Setter Property="BorderColor" Value="{DynamicResource Primary}" />
                    <Setter Property="BackgroundColor" Value="{DynamicResource SelectionAccentStrongBackgroundColor}" />
                    <Setter Property="HasShadow" Value="True" />
                </DataTrigger>
                <DataTrigger TargetType="Frame" Binding="{Binding CanSelectPremiumPlan}" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="BackgroundColor" Value="{DynamicResource DisabledCardBackgroundColor}" />
                </DataTrigger>
            </Frame.Triggers>
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Label Grid.Column="0" Text="{loc:Translate Resource=SetupWizardPageResources, Key=PremiumPlanTitle}" FontSize="20" FontAttributes="Bold" TextColor="{DynamicResource Primary}" />
                    <Label Grid.Column="1" Text="{loc:Translate Resource=SetupWizardPageResources, Key=PremiumPlanBadge}" FontSize="11" Padding="10,4" BackgroundColor="{DynamicResource BadgeAccentBackgroundColor}" TextColor="{DynamicResource Primary}" />
                </Grid>

                <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=PremiumPlanPrice}" FontSize="22" FontAttributes="Bold" TextColor="{DynamicResource Primary}" />

                <VerticalStackLayout Spacing="4">
                    <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=PremiumFeature1}" FontSize="13" />
                    <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=PremiumFeature2}" FontSize="13" />
                    <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=PremiumFeature3}" FontSize="13" />
                    <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=PremiumFeature4}" FontSize="13" />
                    <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=PremiumFeature5}" FontSize="13" />
                    <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=PremiumFeature6}" FontSize="13" />
                </VerticalStackLayout>

                <Button Text="{loc:Translate Resource=SetupWizardPageResources, Key=ChoosePremiumPlanButton}"
                        Command="{Binding SelectPremiumPlanCommand}"
                        IsEnabled="{Binding CanSelectPremiumPlan}"
                        TextColor="{DynamicResource ButtonPrimaryText}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsPremiumPlanSelected}" Value="True">
                            <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button" Binding="{Binding IsPremiumPlanSelected}" Value="False">
                            <Setter Property="BackgroundColor" Value="{DynamicResource Secondary}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </VerticalStackLayout>
        </Frame>
    </VerticalStackLayout>
</ContentView>
