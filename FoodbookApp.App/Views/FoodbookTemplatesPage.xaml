<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Foodbook.ViewModels"
             xmlns:models="clr-namespace:Foodbook.Models"
             xmlns:loc="clr-namespace:Foodbook.Services"
             x:Class="Foodbook.Views.FoodbookTemplatesPage"
             x:DataType="vm:FoodbookTemplatesViewModel"
             x:Name="ThisPage"
             Title="{loc:Translate Resource=PlannerListsPageResources, Key=FoodbooksTab}">

    <Grid RowDefinitions="Auto,*">
        <Button Grid.Row="0"
                Text="+"
                Command="{Binding AddCommand}"
                HorizontalOptions="End"
                Margin="12" />

        <CollectionView Grid.Row="1" ItemsSource="{Binding Templates}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:FoodbookTemplate">
                    <Frame Margin="12,6" Padding="12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="18" />
                            <Label Text="{Binding Description}" FontSize="13" />
                            <Label Text="{Binding DurationDays, StringFormat='Duration: {0} days'}" FontSize="12" />
                            <Grid ColumnDefinitions="*,*,*">
                                <Button Grid.Column="0" Text="Edit" Command="{Binding BindingContext.EditCommand, Source={x:Reference ThisPage}}" CommandParameter="{Binding .}" />
                                <Button Grid.Column="1" Text="Apply" Command="{Binding BindingContext.ApplyCommand, Source={x:Reference ThisPage}}" CommandParameter="{Binding .}" />
                                <Button Grid.Column="2" Text="Delete" Command="{Binding BindingContext.DeleteCommand, Source={x:Reference ThisPage}}" CommandParameter="{Binding .}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
