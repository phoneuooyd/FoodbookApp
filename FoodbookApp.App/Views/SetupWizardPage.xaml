<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Foodbook.ViewModels"
             xmlns:loc="clr-namespace:Foodbook.Services"
             xmlns:views="clr-namespace:Foodbook.Views"
             xmlns:converters="clr-namespace:Foodbook.Converters"
             x:Class="Foodbook.Views.SetupWizardPage"
             x:Name="SetupWizardRoot"
             x:DataType="vm:SetupWizardViewModel"
             Title="{loc:Translate Resource=SetupWizardPageResources, Key=PageTitle}"
             BackgroundColor="{DynamicResource PageBackgroundColor}"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:CultureCodeToNativeNameConverter x:Key="CultureCodeToNativeNameConverter" />
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:StringIsNotNullOrEmptyConverter x:Key="StringIsNotNullOrEmptyConverter" />
            <converters:AppThemeToLocalizedStringConverter x:Key="AppThemeToLocalizedStringConverter" />
            <converters:FontFamilyToLocalizedStringConverter x:Key="FontFamilyToLocalizedStringConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">
            <VerticalStackLayout Spacing="8" Margin="0,4,0,0">
                <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=HeaderTitle}"
                       FontSize="30"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="{DynamicResource Primary}" />
                <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=HeaderSubtitle}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding IsLanguageIngredientsStep}"
                                 Spacing="12">
                <Frame BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}"
                       BorderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                       CornerRadius="10"
                       Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=LanguageSectionTitle}"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource Primary}" />
                        <Picker ItemsSource="{Binding AvailableLanguages}"
                                SelectedItem="{Binding SelectedLanguage}"
                                ItemDisplayBinding="{Binding CultureCode, Converter={StaticResource CultureCodeToNativeNameConverter}}" />

                        <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=IngredientsSectionQuestion}" />
                        <VerticalStackLayout Spacing="8">
                            <RadioButton Content="{loc:Translate Resource=SetupWizardPageResources, Key=IngredientsYes}"
                                         IsChecked="{Binding InstallBasicIngredients}" />
                            <RadioButton Content="{loc:Translate Resource=SetupWizardPageResources, Key=IngredientsNo}"
                                         IsChecked="{Binding InstallBasicIngredients, Converter={StaticResource InvertedBoolConverter}}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding IsAppearanceStep}"
                                 Spacing="12">
                <Frame BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}"
                       BorderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                       CornerRadius="10"
                       Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=AppearanceSectionTitle}"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource Primary}" />

                        <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=ThemeSectionTitle}" />
                        <Picker ItemsSource="{Binding AvailableThemes}"
                                SelectedItem="{Binding SelectedTheme}"
                                ItemDisplayBinding="{Binding ., Converter={StaticResource AppThemeToLocalizedStringConverter}}" />

                        <Label Text="{loc:Translate Resource=SetupWizardPageResources, Key=FontSectionTitle}" />
                        <Picker ItemsSource="{Binding AvailableFontFamilies}"
                                SelectedItem="{Binding SelectedFontFamily}"
                                ItemDisplayBinding="{Binding ., Converter={StaticResource FontFamilyToLocalizedStringConverter}}" />
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding Source={x:Reference SetupWizardRoot}, Path=BindingContext.IsLoginStep}"
                                 Spacing="12">
                <views:SetupLoginPage>
                    <views:SetupLoginPage.BindingContext>
                        <Binding Path="BindingContext.LoginViewModel" Source="{x:Reference SetupWizardRoot}" />
                    </views:SetupLoginPage.BindingContext>
                </views:SetupLoginPage>
            </VerticalStackLayout>

            <views:SetupPlanSelectionPage IsVisible="{Binding Source={x:Reference SetupWizardRoot}, Path=BindingContext.IsPlanSelectionStep}" />

            <Label Text="{Binding StatusMessage}"
                   FontSize="14"
                   HorizontalOptions="Center"
                   IsVisible="{Binding StatusMessage, Converter={StaticResource StringIsNotNullOrEmptyConverter}}" />

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  Margin="0,8,0,0">
                <Button Grid.Column="0"
                        Text="{loc:Translate Resource=SetupWizardPageResources, Key=BackButton}"
                        Command="{Binding PreviousStepCommand}"
                        IsVisible="{Binding CanGoBack}"
                        BackgroundColor="Transparent"
                        BorderColor="{DynamicResource Primary}"
                        BorderWidth="1"
                        TextColor="{DynamicResource Primary}" />
                <Button Grid.Column="1"
                        Text="{loc:Translate Resource=SetupWizardPageResources, Key=NextButton}"
                        Command="{Binding NextStepCommand}"
                        IsVisible="{Binding CanMoveToNextStep}"
                        BackgroundColor="{DynamicResource Primary}"
                        TextColor="{DynamicResource ButtonPrimaryText}" />
                <Button Grid.Column="1"
                        Text="{loc:Translate Resource=SetupWizardPageResources, Key=CompleteSetupButton}"
                        Command="{Binding CompleteSetupCommand}"
                        IsVisible="{Binding IsPlanSelectionStep}"
                        IsEnabled="{Binding CanCompleteSetup}"
                        BackgroundColor="{DynamicResource Primary}"
                        TextColor="{DynamicResource ButtonPrimaryText}" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
