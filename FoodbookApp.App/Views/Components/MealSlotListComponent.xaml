<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:Foodbook.ViewModels"
             xmlns:loc="clr-namespace:Foodbook.Services"
             x:Class="Foodbook.Views.Components.MealSlotListComponent"
             x:Name="MealListRoot">

       <ContentView.Resources>
              <Style x:Key="SectionCardStyle" TargetType="Border">
                     <Setter Property="Padding" Value="16,14" />
                     <Setter Property="StrokeThickness" Value="1" />
                     <Setter Property="Stroke" Value="{DynamicResource DashboardCardStrokeColor}" />
                     <Setter Property="StrokeShape" Value="RoundRectangle 18" />
                     <Setter Property="BackgroundColor" Value="{DynamicResource DashboardCardBackgroundColor}" />
              </Style>

              <Style x:Key="SectionTitleStyle" TargetType="Label">
                     <Setter Property="FontSize" Value="20" />
                     <Setter Property="FontAttributes" Value="Bold" />
                     <Setter Property="TextColor" Value="{DynamicResource PrimaryText}" />
              </Style>
       </ContentView.Resources>

    <Border Style="{StaticResource SectionCardStyle}">
        <VerticalStackLayout Spacing="12">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <HorizontalStackLayout Spacing="8"
                                       VerticalOptions="Center">
                    <Label Text="📅"
                           FontSize="20"
                           VerticalOptions="Center" />
                    <Label Text="{loc:Translate Resource=DietStatisticsPageResources, Key=MealsTodayHeader}"
                           Style="{StaticResource SectionTitleStyle}"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <Button Grid.Column="1"
                        WidthRequest="36"
                        HeightRequest="36"
                        CornerRadius="18"
                        FontSize="20"
                        Padding="0"
                        Text="+"
                        VerticalOptions="Center"
                        Command="{Binding AddMealCommand, Source={x:Reference MealListRoot}}"
                        CommandParameter="{x:Null}" />
            </Grid>

            <Label Text="{loc:Translate Resource=DietStatisticsPageResources, Key=MealsTodayHint}"
                   FontSize="12"
                   TextColor="{DynamicResource SecondaryText}" />

            <Label IsVisible="{Binding IsEmpty, Source={x:Reference MealListRoot}}"
                   Text="{loc:Translate Resource=DietStatisticsPageResources, Key=NoMealsPlaceholder}"
                   FontSize="12"
                   TextColor="{DynamicResource SecondaryText}" />

            <CollectionView ItemsSource="{Binding Data.MealSlots, Source={x:Reference MealListRoot}}"
                            SelectionMode="None"
                            IsVisible="{Binding IsEmpty, Source={x:Reference MealListRoot}, Converter={StaticResource InvertedBoolConverter}}"
                            ItemSizingStrategy="MeasureAllItems">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:MealSlotViewModel">
                    <Border StrokeThickness="0"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="{AppThemeBinding Light=#F7F5FC, Dark={StaticResource Gray700}}"
                            Padding="12,10"
                            Margin="0,0,0,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={x:Reference MealListRoot}, Path=OpenMealDetailCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="10">
                            <Label Text="•"
                                   FontSize="18"
                                   TextColor="{DynamicResource Primary}"
                                   VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="{Binding MealName}"
                                       FontSize="15"
                                       TextColor="{DynamicResource PrimaryText}"
                                       VerticalOptions="Center"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding IngredientsSummary}"
                                       FontSize="11"
                                       TextColor="{DynamicResource SecondaryText}"
                                       VerticalOptions="Center"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2"
                                                 Spacing="2"
                                                 VerticalOptions="Center"
                                                 HorizontalOptions="End">
                                <Label Text="{Binding PortionsSummary}"
                                       FontSize="11"
                                       TextColor="{DynamicResource SecondaryText}"
                                       HorizontalTextAlignment="End" />
                                <Label Text="{Binding Calories, StringFormat='{}{0:F0} kcal'}"
                                       FontSize="11"
                                       TextColor="{DynamicResource SecondaryText}"
                                       HorizontalTextAlignment="End" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        </VerticalStackLayout>
    </Border>
</ContentView>
