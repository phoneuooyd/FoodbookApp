<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:Foodbook.Views.Components"
             xmlns:viewModels="clr-namespace:Foodbook.ViewModels"
             xmlns:loc="clr-namespace:Foodbook.Services"
             x:Class="Foodbook.Views.Components.MealSlotListComponent"
             x:Name="MealListRoot">

    <VerticalStackLayout Spacing="10">
        <Label Text="{loc:Translate Resource=DietStatisticsPageResources, Key=MealsHeader}"
               FontSize="30"
               FontAttributes="Bold"
               TextColor="{DynamicResource PrimaryText}" />

        <Label IsVisible="{Binding IsEmpty, Source={x:Reference MealListRoot}}"
               Text="{loc:Translate Resource=DietStatisticsPageResources, Key=NoMealsPlaceholder}"
               FontSize="12"
               TextColor="{DynamicResource SecondaryText}" />

        <CollectionView ItemsSource="{Binding MealSlots, Source={x:Reference MealListRoot}}"
                        SelectionMode="None"
                        IsVisible="{Binding IsEmpty, Source={x:Reference MealListRoot}, Converter={StaticResource InvertedBoolConverter}}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:MealSlotViewModel">
                    <VerticalStackLayout>
                        <components:MealSlotItemComponent MealName="{Binding MealName}"
                                                          IngredientsSummary="{Binding IngredientsSummary}"
                                                          Calories="{Binding Calories}"
                                                          ItemModel="{Binding .}"
                                                          AddMealCommand="{Binding Source={x:Reference MealListRoot}, Path=AddMealCommand}"
                                                          OpenMealDetailCommand="{Binding Source={x:Reference MealListRoot}, Path=OpenMealDetailCommand}" />
                        <BoxView HeightRequest="1"
                                 Margin="0,2,0,4"
                                 Color="{DynamicResource DashboardCardStrokeColor}" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentView>
