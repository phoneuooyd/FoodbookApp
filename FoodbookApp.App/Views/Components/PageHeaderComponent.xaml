<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Foodbook.Views.Components.PageHeaderComponent"
             x:Name="HeaderRoot">
    <Grid Padding="{Binding HeaderPadding, Source={x:Reference HeaderRoot}}"
          Background="{DynamicResource AppHeroGradientBrush}">
        <Border WidthRequest="132"
                HeightRequest="132"
                HorizontalOptions="End"
                VerticalOptions="Start"
                TranslationX="24"
                TranslationY="-38"
                StrokeThickness="0"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 66"
                BackgroundColor="{DynamicResource AppHeroBubbleColorStrong}" />
        <Border WidthRequest="72"
                HeightRequest="72"
                HorizontalOptions="End"
                VerticalOptions="Start"
                TranslationX="-8"
                TranslationY="14"
                StrokeThickness="0"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 36"
                BackgroundColor="{DynamicResource AppHeroBubbleColorMedium}" />

        <VerticalStackLayout Spacing="2"
                             VerticalOptions="Center"
                             ZIndex="1">
            <Label Text="{Binding Title, Source={x:Reference HeaderRoot}}"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource AppHeroTitleTextColor}" />
            <Label Text="{Binding Subtitle, Source={x:Reference HeaderRoot}}"
                   FontSize="12"
                   TextColor="{DynamicResource AppHeroSubtitleTextColor}" />
        </VerticalStackLayout>
    </Grid>
</ContentView>
