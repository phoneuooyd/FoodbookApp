<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Foodbook.Services"
             x:Class="Foodbook.Views.Components.CalorieSummaryCardComponent"
             x:Name="CalorieCardRoot">

    <Border Padding="16"
            StrokeThickness="1"
            Stroke="{DynamicResource DashboardCardStrokeColor}"
            StrokeShape="RoundRectangle 20"
            BackgroundColor="{DynamicResource DashboardCardBackgroundColor}">
        <Border.Shadow>
            <Shadow Brush="{DynamicResource DashboardCardShadowBrush}"
                    Offset="0,7"
                    Radius="18"
                    Opacity="0.15" />
        </Border.Shadow>

        <VerticalStackLayout Spacing="8">
                     <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                                 <Label Text="{Binding Data.ConsumedCalories, Source={x:Reference CalorieCardRoot}, StringFormat='{}{0:F0} kcal'}"
                                      FontSize="46"
                                      FontAttributes="Bold"
                                      TextColor="{DynamicResource PrimaryText}" />
                            <Border Grid.Column="1"
                                          WidthRequest="30"
                                          HeightRequest="30"
                                          StrokeThickness="0"
                                          Stroke="Transparent"
                                          StrokeShape="RoundRectangle 15"
                                          BackgroundColor="{DynamicResource Secondary}"
                                          VerticalOptions="Start">
                                   <Border.GestureRecognizers>
                                          <TapGestureRecognizer Command="{Binding OpenSettingsCommand, Source={x:Reference CalorieCardRoot}}" />
                                   </Border.GestureRecognizers>
                                   <Label Text="⚙"
                                             FontSize="14"
                                             TextColor="{DynamicResource OnSecondaryText}"
                                             HorizontalTextAlignment="Center"
                                             VerticalTextAlignment="Center" />
                            </Border>
                     </Grid>

            <!--<Label Text="{Binding Data.GoalCalories, Source={x:Reference CalorieCardRoot}, StringFormat='{loc:Translate Resource=DietStatisticsPageResources, Key=CaloriesGoal}: {0:F0}'}"
                   FontSize="12"
                   TextColor="{DynamicResource SecondaryText}" />-->

            <GraphicsView x:Name="CalorieRangeBar"
                          HeightRequest="26"
                          Margin="0,5,0,0" />

            <Grid ColumnDefinitions="Auto,*,Auto"
                  Margin="0,2,0,0">
                <Label Text="{Binding Data.CaloriesMin, Source={x:Reference CalorieCardRoot}, StringFormat='{}{0:F0}'}"
                       FontSize="12"
                       TextColor="{DynamicResource SecondaryText}" />
                <Label Grid.Column="2"
                       Text="{Binding Data.CaloriesMax, Source={x:Reference CalorieCardRoot}, StringFormat='{}{0:F0}'}"
                       FontSize="12"
                       TextColor="{DynamicResource SecondaryText}" />
            </Grid>

            <Label Text="{Binding Source={x:Reference CalorieCardRoot}, Path=TargetRangeText}"
                   FontSize="12"
                   TextColor="{DynamicResource SecondaryText}" />
        </VerticalStackLayout>
    </Border>
</ContentView>
