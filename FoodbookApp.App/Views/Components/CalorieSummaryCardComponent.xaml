<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Foodbook.Services"
             x:Class="Foodbook.Views.Components.CalorieSummaryCardComponent"
             x:Name="CalorieCardRoot">

    <Border Padding="16"
            StrokeThickness="1"
            Stroke="{DynamicResource DashboardCardStrokeColor}"
            StrokeShape="RoundRectangle 20"
            BackgroundColor="{DynamicResource DashboardCardBackgroundColor}">
        <Border.Shadow>
            <Shadow Brush="{DynamicResource DashboardCardShadowBrush}"
                    Offset="0,7"
                    Radius="18"
                    Opacity="0.15" />
        </Border.Shadow>

        <VerticalStackLayout Spacing="8">
            <Label Text="{Binding ConsumedCalories, Source={x:Reference CalorieCardRoot}, StringFormat='{}{0:F0} kcal'}"
                   FontSize="46"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource PrimaryText}" />

            <Label Text="{Binding GoalCalories, Source={x:Reference CalorieCardRoot}, StringFormat='{loc:Translate Resource=DietStatisticsPageResources, Key=CaloriesGoal}: {0:F0}'}"
                   FontSize="14"
                   TextColor="{DynamicResource SecondaryText}" />

            <GraphicsView x:Name="CalorieRangeBar"
                          HeightRequest="26"
                          Margin="0,6,0,0" />

            <Grid ColumnDefinitions="Auto,*,Auto"
                  Margin="0,2,0,0">
                <Label Text="{Binding CaloriesMin, Source={x:Reference CalorieCardRoot}, StringFormat='{}{0:F0}'}"
                       FontSize="12"
                       TextColor="{DynamicResource SecondaryText}" />
                <Label Grid.Column="2"
                       Text="{Binding CaloriesMax, Source={x:Reference CalorieCardRoot}, StringFormat='{}{0:F0}'}"
                       FontSize="12"
                       TextColor="{DynamicResource SecondaryText}" />
            </Grid>

            <Label Text="{Binding Source={x:Reference CalorieCardRoot}, Path=TargetRangeText}"
                   FontSize="12"
                   TextColor="{DynamicResource SecondaryText}" />
        </VerticalStackLayout>
    </Border>
</ContentView>
