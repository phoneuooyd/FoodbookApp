<?xml version="1.0" encoding="utf-8" ?>
<mct:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
           xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
           xmlns:mct="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
           x:Class="Foodbook.Views.Components.RegisterPopup"
           x:Name="ThisPopup"
           CanBeDismissedByTappingOutsideOfPopup="True"
           Padding="0"
           Margin="0">

    <Border BackgroundColor="{DynamicResource PopupBackgroundColor}"
            StrokeShape="RoundRectangle 16"
            StrokeThickness="1"
            Stroke="{DynamicResource Secondary}"
            MinimumWidthRequest="320"
            MaximumWidthRequest="520">

        <Grid RowDefinitions="Auto,*,Auto" Padding="0">
            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="16,14" BackgroundColor="{DynamicResource ShellBackgroundColor}">
                <Label Grid.Column="0"
                       Text="Rejestracja"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource ShellTitleColor}"
                       HorizontalTextAlignment="Center"
                       VerticalOptions="Center" />

                <Button Grid.Column="1"
                        Text="X"
                        FontSize="18"
                        WidthRequest="32"
                        HeightRequest="32"
                        CornerRadius="16"
                        BackgroundColor="Transparent"
                        TextColor="{DynamicResource ShellTitleColor}"
                        Command="{Binding CloseCommand, Source={x:Reference ThisPopup}}" />
            </Grid>

            <!-- Body -->
            <ScrollView Grid.Row="1" Padding="16,12">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Utw rz konto Supabase"
                           FontSize="12"
                           TextColor="{DynamicResource SecondaryText}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Email" FontSize="12" FontAttributes="Bold" />
                        <Border Style="{StaticResource ModernBorder}">
                            <Entry x:Name="EmailEntry"
                                   Style="{StaticResource ModernEntry}"
                                   Placeholder="name@example.com"
                                   Keyboard="Email" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Has o" FontSize="12" FontAttributes="Bold" />
                        <Border Style="{StaticResource ModernBorder}">
                            <Entry x:Name="PasswordEntry"
                                   Style="{StaticResource ModernEntry}"
                                   Placeholder="minimum 6 znak w"
                                   IsPassword="True" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Powt rz has o" FontSize="12" FontAttributes="Bold" />
                        <Border Style="{StaticResource ModernBorder}">
                            <Entry x:Name="ConfirmPasswordEntry"
                                   Style="{StaticResource ModernEntry}"
                                   Placeholder="powt rz has o"
                                   IsPassword="True" />
                        </Border>
                    </VerticalStackLayout>

                    <Label x:Name="StatusLabel"
                           FontSize="12"
                           TextColor="{DynamicResource SecondaryText}" />
                </VerticalStackLayout>
            </ScrollView>

            <!-- Footer -->
            <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Padding="16,12" BackgroundColor="{DynamicResource ShellBackgroundColor}">
                <Button Grid.Column="0"
                        Text="Zarejestruj"
                        StyleClass="Primary"
                        Command="{Binding RegisterCommand, Source={x:Reference ThisPopup}}" />

                <Label Grid.Column="1" />

                <Button Grid.Column="2"
                        Text="Anuluj"
                        BackgroundColor="Transparent"
                        TextColor="{DynamicResource ShellTitleColor}"
                        Command="{Binding CloseCommand, Source={x:Reference ThisPopup}}" />
            </Grid>
        </Grid>
    </Border>
</mct:Popup>
