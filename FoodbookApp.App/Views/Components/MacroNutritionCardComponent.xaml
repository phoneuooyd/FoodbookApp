<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Foodbook.Services"
             x:Class="Foodbook.Views.Components.MacroNutritionCardComponent"
             x:Name="MacroCardRoot">

    <Border Padding="16"
            StrokeThickness="1"
            Stroke="{DynamicResource DashboardCardStrokeColor}"
            StrokeShape="RoundRectangle 20"
            BackgroundColor="{DynamicResource DashboardCardBackgroundColor}">
        <VerticalStackLayout Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="{loc:Translate Resource=DietStatisticsPageResources, Key=NutritionCardTitle}"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource PrimaryText}" />
                <Label Grid.Column="1"
                       Text=">"
                       FontSize="22"
                       TextColor="{DynamicResource SecondaryText}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnToggleTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <VerticalStackLayout x:Name="MacroBody"
                                 IsVisible="True"
                                 Spacing="12">
                <Grid ColumnDefinitions="*,*,*"
                      ColumnSpacing="8">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <HorizontalStackLayout Spacing="5">
                            <Ellipse WidthRequest="8" HeightRequest="8" Fill="{DynamicResource DietStatsCarbsColor}" VerticalOptions="Center" />
                            <Label Text="{loc:Translate Resource=DietStatisticsPageResources, Key=MacroCarbs}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                        </HorizontalStackLayout>
                        <Label Text="{Binding ConsumedCarbs, Source={x:Reference MacroCardRoot}, StringFormat='{}{0:F1} g'}" FontSize="20" FontAttributes="Bold" TextColor="{DynamicResource PrimaryText}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <HorizontalStackLayout Spacing="5">
                            <Ellipse WidthRequest="8" HeightRequest="8" Fill="{DynamicResource DietStatsFatColor}" VerticalOptions="Center" />
                            <Label Text="{loc:Translate Resource=DietStatisticsPageResources, Key=MacroFat}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                        </HorizontalStackLayout>
                        <Label Text="{Binding ConsumedFat, Source={x:Reference MacroCardRoot}, StringFormat='{}{0:F1} g'}" FontSize="20" FontAttributes="Bold" TextColor="{DynamicResource PrimaryText}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2" Spacing="2">
                        <HorizontalStackLayout Spacing="5">
                            <Ellipse WidthRequest="8" HeightRequest="8" Fill="{DynamicResource DietStatsProteinColor}" VerticalOptions="Center" />
                            <Label Text="{loc:Translate Resource=DietStatisticsPageResources, Key=MacroProtein}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                        </HorizontalStackLayout>
                        <Label Text="{Binding ConsumedProtein, Source={x:Reference MacroCardRoot}, StringFormat='{}{0:F1} g'}" FontSize="20" FontAttributes="Bold" TextColor="{DynamicResource PrimaryText}" />
                    </VerticalStackLayout>
                </Grid>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="8">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <GraphicsView x:Name="RecommendedChart" HeightRequest="142" WidthRequest="142" HorizontalOptions="Center" />
                        <Label Text="{loc:Translate Resource=DietStatisticsPageResources, Key=MacroRecommended}" HorizontalTextAlignment="Center" FontAttributes="Bold" TextColor="{DynamicResource PrimaryText}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <GraphicsView x:Name="ActualChart" HeightRequest="142" WidthRequest="142" HorizontalOptions="Center" />
                        <Label Text="{loc:Translate Resource=DietStatisticsPageResources, Key=MacroActual}" HorizontalTextAlignment="Center" FontAttributes="Bold" TextColor="{DynamicResource PrimaryText}" />
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </Border>
</ContentView>
