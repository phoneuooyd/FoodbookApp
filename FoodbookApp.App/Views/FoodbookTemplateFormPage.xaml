<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Foodbook.ViewModels"
             xmlns:loc="clr-namespace:Foodbook.Services"
             x:Class="Foodbook.Views.FoodbookTemplateFormPage"
             x:DataType="vm:FoodbookTemplateFormViewModel"
             Title="{loc:Translate Resource=PlannerListsPageResources, Key=FoodbookTemplateFormTitle}">

    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="16">
            <Entry Placeholder="Plan ID" Text="{Binding SourcePlanId}" />
            <Entry Placeholder="Name" Text="{Binding Name}" />
            <Editor Placeholder="Description" Text="{Binding Description}" AutoSize="TextChanges" />
            <HorizontalStackLayout>
                <Label Text="Public" VerticalOptions="Center" />
                <Switch IsToggled="{Binding IsPublic}" />
            </HorizontalStackLayout>
            <Button Text="Save" Command="{Binding SaveCommand}" />
            <Button Text="Cancel" Command="{Binding CancelCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
