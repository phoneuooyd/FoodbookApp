<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Foodbook.ViewModels"
             xmlns:loc="clr-namespace:Foodbook.Services"
             x:Class="Foodbook.Views.FoodbookTemplateFormPage"
             x:DataType="vm:FoodbookTemplateFormViewModel"
             Title="{loc:Translate Resource=PlannerTemplatesResources, Key=TemplateFormTitle}"
             BackgroundColor="{DynamicResource PageBackgroundColor}">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="{loc:Translate Resource=PlannerTemplatesResources, Key=TemplateName}" TextColor="{DynamicResource PrimaryText}" />
            <Entry Text="{Binding Name}" Placeholder="{loc:Translate Resource=PlannerTemplatesResources, Key=TemplateNamePlaceholder}" />

            <Label Text="{loc:Translate Resource=PlannerTemplatesResources, Key=TemplateDescription}" TextColor="{DynamicResource PrimaryText}" />
            <Editor Text="{Binding Description}" HeightRequest="120" />

            <HorizontalStackLayout Spacing="10">
                <CheckBox IsChecked="{Binding IsPublic}" />
                <Label Text="{loc:Translate Resource=PlannerTemplatesResources, Key=TemplatePublic}" VerticalTextAlignment="Center" />
            </HorizontalStackLayout>

            <Button Text="{loc:Translate Resource=PlannerTemplatesResources, Key=SaveTemplate}" Command="{Binding SaveCommand}" BackgroundColor="{DynamicResource Primary}" TextColor="{DynamicResource ButtonPrimaryText}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
