<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Foodbook.Services"
             xmlns:vm="clr-namespace:Foodbook.ViewModels"
             xmlns:models="clr-namespace:Foodbook.Models"
             xmlns:converters="clr-namespace:Foodbook.Converters"
             xmlns:resources="clr-namespace:FoodbookApp.Localization"
             xmlns:controls="clr-namespace:Foodbook.Views.Components"
             x:Class="Foodbook.Views.HomePage"
             x:Name="HomePageView"
             x:DataType="vm:HomeViewModel"
             Title="{loc:Translate Resource=HomePageResources, Key=Title}"
             BackgroundColor="{DynamicResource PageBackgroundColor}"
             Shell.NavBarIsVisible="false">
    <ContentPage.Resources>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        <converters:FormatWithResourceConverter x:Key="FormatWithResourceConverter" />
        
        <!-- Enhanced Card Style with better separation -->
        <Style x:Key="DashboardCardStyle" TargetType="Frame">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}" />
            <Setter Property="HasShadow" Value="True" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="12,8" />
            <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
        </Style>
        
        <!-- Card Title Style -->
        <Style x:Key="CardTitleStyle" TargetType="Label">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontAttributes" Value="Bold" />
            <!-- Use single dynamic resource so ThemeService runtime updates propagate -->
            <Setter Property="TextColor" Value="{DynamicResource Primary}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        
        <!-- Large Number Style -->
        <Style x:Key="StatNumberStyle" TargetType="Label">
            <Setter Property="FontSize" Value="32" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
            <Setter Property="TextColor" Value="{DynamicResource Primary}" />
            <Setter Property="Margin" Value="0,4" />
        </Style>
        
        <!-- Description Style -->
        <Style x:Key="StatDescriptionStyle" TargetType="Label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        
        <!-- Card Button Style -->
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="TextColor" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="HeightRequest" Value="40" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Margin" Value="0,12,0,0" />
            <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
        </Style>
        
        <!-- Disabled Button Style -->
        <Style x:Key="DisabledButtonStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray400}}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HeightRequest" Value="40" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Margin" Value="0,12,0,0" />
        </Style>
        
        <!-- Emoji Style -->
        <Style x:Key="EmojiStyle" TargetType="Label">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        
        <!-- Micro Stat Style -->
        <Style x:Key="MicroStatStyle" TargetType="Label">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" />
        </Style>

        <!-- Planned Meal Styles -->
        <Style x:Key="DateHeaderStyle" TargetType="Label">
            <!-- reduced from 16 -->
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontAttributes" Value="Bold" />
            <!-- Make date header light in dark mode -->
            <Setter Property="TextColor" Value="{AppThemeBinding Light={DynamicResource Primary}, Dark=White}" />
            <Setter Property="Margin" Value="0,8,0,4" />
        </Style>

        <Style x:Key="MealItemStyle" TargetType="Label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
            <Setter Property="Margin" Value="16,2,0,2" />
        </Style>

        <!-- Clickable Meal Item Style -->
        <Style x:Key="ClickableMealItemStyle" TargetType="Frame">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="HasShadow" Value="False" />
            <Setter Property="BorderColor" Value="Transparent" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="8,1" />
        </Style>
    </ContentPage.Resources>

    <ScrollView BackgroundColor="Transparent">
        <StackLayout Padding="16" Spacing="0" 
                     BackgroundColor="{DynamicResource PageBackgroundColor}">

            <!-- Header with gradient-like effect -->
            <Border BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}" 
                   StrokeShape="RoundRectangle 20"
                   StrokeThickness="1"
                   Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                   Margin="0,0,0,20"
                   Padding="20,16">
                <Border.Shadow>
                    <Shadow Brush="{AppThemeBinding Light=#10000000, Dark=#20000000}" Offset="0,2" Radius="4" Opacity="0.5" />
                </Border.Shadow>
                <StackLayout>
                    <Label Text="{loc:Translate Resource=HomePageResources, Key=Welcome}"
                           FontSize="26"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="{DynamicResource Primary}"
                           Margin="0,4" />
                    <Label Text="{loc:Translate Resource=HomePageResources, Key=Subtitle}"
                           FontSize="14"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                           Margin="0,0,0,4" />
                </StackLayout>
            </Border>

            <!-- Loading indicator -->
            <ActivityIndicator IsVisible="{Binding IsLoading}" 
                             IsRunning="{Binding IsLoading}" 
                             Color="{DynamicResource Primary}"
                             HorizontalOptions="Center"
                             HeightRequest="60"
                             WidthRequest="60"
                             Margin="0,40" />

            <!-- Dashboard Grid -->
            <Grid IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                  ColumnDefinitions="*,*" 
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                  ColumnSpacing="0"
                  RowSpacing="8">

                <!-- Main Stats Card: Recipes and Plans -->
                <Border Grid.Row="0" Grid.ColumnSpan="2" 
                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        Padding="20"
                        Margin="12,8">
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Light=#10000000, Dark=#20000000}" Offset="0,2" Radius="4" Opacity="0.5" />
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*,1,*" ColumnSpacing="20">
                        <!-- Recipes -->
                        <StackLayout Grid.Column="0">
                            <Label Text="📖" Style="{StaticResource EmojiStyle}" />
                            <Label Text="{loc:Translate Resource=HomePageResources, Key=Recipes}" Style="{StaticResource CardTitleStyle}" />
                            <Label Text="{Binding RecipeCount}" Style="{StaticResource StatNumberStyle}" />
                            <Label Text="{loc:Translate Resource=HomePageResources, Key=SavedRecipes}" Style="{StaticResource StatDescriptionStyle}" />
                        </StackLayout>
                        
                        <!-- Separator Line -->
                        <BoxView Grid.Column="1" 
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" 
                                 WidthRequest="1" 
                                 HorizontalOptions="Center" />
                        
                        <!-- Plans -->
                        <StackLayout Grid.Column="2">
                            <Label Text="📋" Style="{StaticResource EmojiStyle}" />
                            <Label Text="{loc:Translate Resource=HomePageResources, Key=Plans}" Style="{StaticResource CardTitleStyle}" />
                            <Label Text="{Binding PlanCount}" Style="{StaticResource StatNumberStyle}" />
                            <Label Text="{loc:Translate Resource=HomePageResources, Key=ActiveLists}" Style="{StaticResource StatDescriptionStyle}" />
                        </StackLayout>
                    </Grid>
                </Border>

                <!-- Planned Meals History Card -->
                <Border Grid.Row="1" Grid.ColumnSpan="2" 
                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        Padding="20"
                        Margin="12,8">
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Light=#10000000, Dark=#20000000}" Offset="0,2" Radius="4" Opacity="0.5" />
                    </Border.Shadow>
                    <StackLayout>
                        <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="8" Margin="0,0,0,16">
                            <Label Text="📅" FontSize="24" />
                            <!-- Override title color to be light in dark mode -->
                            <Label Text="{loc:Translate Resource=HomePageResources, Key=PlannedMealsHeader}" Style="{StaticResource CardTitleStyle}" Margin="0" TextColor="{AppThemeBinding Light={DynamicResource Primary}, Dark=White}" />
                        </StackLayout>
                        
                        <!-- Period Selection Button for Planned Meals -->
                        <Button Text="{Binding PlannedMealsPeriodDisplay, StringFormat='📅 {0}'}"
                                Command="{Binding ChangePlannedMealsPeriodCommand}"
                                BackgroundColor="{DynamicResource Primary}"
                                TextColor="White"
                                FontSize="12"
                                FontAttributes="Bold"
                                HeightRequest="30"
                                CornerRadius="6"
                                Margin="0,0,0,12"
                                HorizontalOptions="Center" />
                        
                        <Label FontSize="12"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                               Margin="0,0,0,8"
                               Text="{loc:Translate Resource=HomePageResources, Key=ClickRecipeHint}" />

                        <!-- Empty state info when no meals -->
                        <Label IsVisible="{Binding HasPlannedMeals, Converter={StaticResource InvertedBoolConverter}}"
                               FontSize="12"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                               Margin="0,0,0,8"
                               Text="{loc:Translate Resource=HomePageResources, Key=NoPlannedMealsMessage}" />
                        
                        <!-- Scrollable CollectionView with limited height (expands on Today) -->
                        <ScrollView MaximumHeightRequest="{Binding PlannedMealsMaxHeight}"
                                    VerticalScrollBarVisibility="Always">
                            <CollectionView ItemsSource="{Binding PlannedMealHistory}"
                                            ItemSizingStrategy="MeasureAllItems">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PlannedMealGroup">
                                        <StackLayout Margin="0,4">
                                            <!-- Date Header -->
                                            <Label Text="{Binding DateLabel}" 
                                                   Style="{StaticResource DateHeaderStyle}" />
                                            
                                            <!-- Meals for this date -->
                                            <CollectionView ItemsSource="{Binding Meals}"
                                                            ItemSizingStrategy="MeasureAllItems">
                                                <CollectionView.ItemTemplate>
                                                    <DataTemplate x:DataType="{x:Type models:PlannedMeal}">
                                                        <Frame Style="{StaticResource ClickableMealItemStyle}">
                                                            <Frame.GestureRecognizers>
                                                                <TapGestureRecognizer Command="{Binding Source={x:Reference Name=HomePageView}, Path=BindingContext.ShowMealDetailsPopupCommand}" CommandParameter="{Binding .}" />
                                                            </Frame.GestureRecognizers>
                                                            <StackLayout Orientation="Horizontal">
                                                                <Label Text="•" 
                                                                       FontSize="16"
                                                                       TextColor="{DynamicResource Primary}"
                                                                       VerticalOptions="Center"
                                                                       Margin="0,0,8,0" />
                                                                <Label Text="{Binding Recipe.Name}" 
                                                                       FontSize="16"
                                                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                                                                       VerticalOptions="Center"
                                                                       LineBreakMode="TailTruncation"
                                                                       HorizontalOptions="FillAndExpand" />
                                                                <Label Text="{Binding Portions, Converter={StaticResource FormatWithResourceConverter}, ConverterParameter=PortionsFormat}"
                                                                       FontSize="12"
                                                                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                                                       VerticalOptions="Center"
                                                                       Margin="8,0,0,0" />
                                                            </StackLayout>
                                                        </Frame>
                                                    </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                            </CollectionView>
                                        </StackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </ScrollView>
                    </StackLayout>
                </Border>

                <!-- Nutrition Stats Card -->
                <Border Grid.Row="2" Grid.ColumnSpan="2" 
                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        Padding="20"
                        Margin="12,8">
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Light=#10000000, Dark=#20000000}" Offset="0,2" Radius="4" Opacity="0.5" />
                    </Border.Shadow>
                    <StackLayout>
                        <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="8" Margin="0,0,0,16">
                            <Label Text="📊" FontSize="24" />
                            <Label Text="{loc:Translate Resource=HomePageResources, Key=NutritionStatsHeader}" Style="{StaticResource CardTitleStyle}" Margin="0" />
                        </StackLayout>

                        <!-- Period Selection Button -->
                        <Button Text="{Binding NutritionPeriodDisplay, StringFormat='📅 {0}'}"
                                Command="{Binding ChangeNutritionPeriodCommand}"
                                BackgroundColor="{DynamicResource Primary}"
                                TextColor="White"
                                FontSize="14"
                                FontAttributes="Bold"
                                HeightRequest="35"
                                CornerRadius="8"
                                Margin="0,0,0,16"
                                HorizontalOptions="Center" />

                        <!-- Top row - Calories (full width) -->
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}" 
                               StrokeShape="RoundRectangle 12"
                               StrokeThickness="0"
                               Stroke="Transparent"
                               Padding="16,20" 
                               Margin="0,0,0,12">
                            <StackLayout>
                                <Label Text="🔥" FontSize="28" HorizontalTextAlignment="Center" />
                                <Label Text="{loc:Translate Resource=HomePageResources, Key=Calories}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" 
                                       Margin="0,8,0,12" />
                                <Label Text="{Binding CaloriesDisplay}" 
                                       FontSize="28"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{DynamicResource Primary}" />
                            </StackLayout>
                        </Border>

                        <!-- Bottom row - Protein, Carbs, Fats -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                            <Border Grid.Column="0" 
                                   BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}" 
                                   StrokeShape="RoundRectangle 12"
                                   StrokeThickness="0"
                                   Stroke="Transparent"
                                   Padding="12,16">
                                <StackLayout>
                                    <Label Text="🥩" FontSize="20" HorizontalTextAlignment="Center" />
                                    <Label Text="{loc:Translate Resource=HomePageResources, Key=Protein}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" 
                                           Margin="0,4,0,8" />
                                    <Label Text="{Binding ProteinDisplay}" Style="{StaticResource MicroStatStyle}" />
                                </StackLayout>
                            </Border>

                            <Border Grid.Column="1" 
                                   BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}" 
                                   StrokeShape="RoundRectangle 12"
                                   StrokeThickness="0"
                                   Stroke="Transparent"
                                   Padding="12,16">
                                <StackLayout>
                                    <Label Text="🌾" FontSize="20" HorizontalTextAlignment="Center" />
                                    <Label Text="{loc:Translate Resource=HomePageResources, Key=Carbs}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" 
                                           Margin="0,4,0,8" />
                                    <Label Text="{Binding CarbsDisplay}" Style="{StaticResource MicroStatStyle}" />
                                </StackLayout>
                            </Border>

                            <Border Grid.Column="2" 
                                   BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}" 
                                   StrokeShape="RoundRectangle 12"
                                   StrokeThickness="0"
                                   Stroke="Transparent"
                                   Padding="12,16">
                                <StackLayout>
                                    <Label Text="🧈" FontSize="20" HorizontalTextAlignment="Center" />
                                    <Label Text="{loc:Translate Resource=HomePageResources, Key=Fats}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" 
                                           Margin="0,4,0,8" />
                                    <Label Text="{Binding FatDisplay}" Style="{StaticResource MicroStatStyle}" />
                                </StackLayout>
                            </Border>
                        </Grid>

                        <Label IsVisible="{Binding HasNutritionData, Converter={StaticResource InvertedBoolConverter}}"
                               FontSize="12"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                               Margin="0,16,0,0"
                               Text="{loc:Translate Resource=HomePageResources, Key=NoNutritionData}" />
                    </StackLayout>
                </Border>

                <!-- Profile Card (navigates to ProfilePage) -->
                <Border Grid.Row="3" Grid.ColumnSpan="2" 
                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        Stroke="{DynamicResource Primary}"
                        Padding="20"
                        Margin="12,8">
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Light=#10000000, Dark=#20000000}" Offset="0,2" Radius="4" Opacity="0.5" />
                    </Border.Shadow>
                    <StackLayout Orientation="Horizontal" Spacing="12" VerticalOptions="Center" Padding="8">
                        <Label Text="👤" FontSize="28" VerticalOptions="Center" />
                        <StackLayout HorizontalOptions="FillAndExpand">
                            <Label Text="{loc:Translate Resource=HomePageResources, Key=Profile}" Style="{StaticResource CardTitleStyle}" Margin="0" />
                            <Label Text="{loc:Translate Resource=HomePageResources, Key=ProfileSubtitle}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                        </StackLayout>
                        <Button Text="{loc:Translate Resource=HomePageResources, Key=GoToProfile}"
                                BackgroundColor="{DynamicResource Primary}"
                                TextColor="White"
                                CornerRadius="8"
                                HeightRequest="40"
                                Clicked="OnOpenProfileClicked" />
                    </StackLayout>
                </Border>

                <!-- Archive Card -->
                <Border Grid.Row="4" Grid.Column="0" 
                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        Padding="20"
                        Margin="12,8">
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Light=#10000000, Dark=#20000000}" Offset="0,2" Radius="4" Opacity="0.5" />
                    </Border.Shadow>
                    <StackLayout>
                        <Label Text="📁" Style="{StaticResource EmojiStyle}" />
                        <Label Text="{loc:Translate Resource=HomePageResources, Key=Archive}" Style="{StaticResource CardTitleStyle}" />
                        <Label Text="{Binding ArchivedPlanCount}" Style="{StaticResource StatNumberStyle}" />
                        <Label Text="{loc:Translate Resource=HomePageResources, Key=InArchive}" Style="{StaticResource StatDescriptionStyle}" />
                        <Button Clicked="OnArchiveClicked"
                                Style="{StaticResource CardButtonStyle}"
                                Text="{loc:Translate Resource=HomePageResources, Key=GoToArchive}" />
                    </StackLayout>
                </Border>

                <!-- Settings Card -->
                <Border Grid.Row="4" Grid.Column="1" 
                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray900}}"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        Padding="20"
                        Margin="12,8">
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Light=#10000000, Dark=#20000000}" Offset="0,2" Radius="4" Opacity="0.5" />
                    </Border.Shadow>
                    <StackLayout>
                        <Label Text="⚙️" Style="{StaticResource EmojiStyle}" />
                        <Label Text="{loc:Translate Resource=HomePageResources, Key=Settings}" Style="{StaticResource CardTitleStyle}" />
                        <Label Text="🛠️" Style="{StaticResource StatNumberStyle}" />
                        <Label Text="{loc:Translate Resource=HomePageResources, Key=Customize}" Style="{StaticResource StatDescriptionStyle}" />
                        <Button Style="{StaticResource CardButtonStyle}"
                                Text="{loc:Translate Resource=HomePageResources, Key=GoToSettings}"
                                Clicked="OnSettingsClicked" />
                    </StackLayout>
                </Border>

            </Grid>
        </StackLayout>
    </ScrollView>
</ContentPage>