<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Foodbook.Services"
             xmlns:vm="clr-namespace:Foodbook.ViewModels"
             xmlns:models="clr-namespace:Foodbook.Models"
             xmlns:converters="clr-namespace:Foodbook.Converters"
             x:Class="Foodbook.Views.HomePage"
             x:Name="HomePageView"
             x:DataType="vm:HomeViewModel"
             Title="{loc:Translate Resource=HomePageResources, Key=Title}"
             BackgroundColor="{DynamicResource PageBackgroundColor}"
             Shell.NavBarIsVisible="false">
    <ContentPage.Resources>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        <converters:FormatWithResourceConverter x:Key="FormatWithResourceConverter" />

        <Style x:Key="HeroEyebrowStyle" TargetType="Label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="{DynamicResource AppHeroEyebrowTextColor}" />
        </Style>

        <Style x:Key="HeroTitleStyle" TargetType="Label">
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="{DynamicResource AppHeroTitleTextColor}" />
        </Style>

        <Style x:Key="HeroSubtitleStyle" TargetType="Label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="{DynamicResource AppHeroSubtitleTextColor}" />
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{DynamicResource DashboardCardBackgroundColor}" />
            <Setter Property="StrokeShape" Value="RoundRectangle 22" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Stroke" Value="{DynamicResource DashboardCardStrokeColor}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow Brush="{DynamicResource DashboardCardShadowBrush}"
                            Offset="0,6"
                            Radius="16"
                            Opacity="0.8" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="Label">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="{DynamicResource PrimaryText}" />
        </Style>

        <Style x:Key="SectionSubtitleStyle" TargetType="Label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextColor" Value="{DynamicResource SecondaryText}" />
        </Style>

        <Style x:Key="PeriodButtonStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="{DynamicResource Secondary}" />
            <Setter Property="TextColor" Value="{DynamicResource FrameTextColor}" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="HeightRequest" Value="32" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontAttributes" Value="Bold" />
        </Style>

        <Style x:Key="MacroValueStyle" TargetType="Label">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="{DynamicResource PrimaryText}" />
        </Style>
    </ContentPage.Resources>

    <ScrollView BackgroundColor="Transparent"
                VerticalScrollBarVisibility="Never">
        <VerticalStackLayout Padding="16,12,16,96"
                             Spacing="0"
                             BackgroundColor="{DynamicResource PageBackgroundColor}">

            <Grid Margin="-16,-12,-16,18"
                  Padding="24,28,24,24"
                  MinimumHeightRequest="170"
                  Background="{DynamicResource AppHeroGradientBrush}">
                <Border WidthRequest="120"
                        HeightRequest="120"
                        StrokeThickness="0"
                        Stroke="Transparent"
                        BackgroundColor="{DynamicResource AppHeroBubbleColorStrong}"
                        StrokeShape="RoundRectangle 60"
                        HorizontalOptions="End"
                        VerticalOptions="Start"
                        TranslationX="26"
                        TranslationY="-34" />
                <Border WidthRequest="88"
                        HeightRequest="88"
                        StrokeThickness="0"
                        Stroke="Transparent"
                        BackgroundColor="{DynamicResource AppHeroBubbleColorMedium}"
                        StrokeShape="RoundRectangle 44"
                        HorizontalOptions="Start"
                        VerticalOptions="End"
                        TranslationX="8"
                        TranslationY="28" />

                <Grid RowDefinitions="Auto,Auto"
                      RowSpacing="18"
                      ZIndex="1">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{loc:Translate Resource=HomePageResources, Key=Title}"
                               Style="{StaticResource HeroEyebrowStyle}" />
                        <Label Text="{loc:Translate Resource=HomePageResources, Key=Welcome}"
                               Style="{StaticResource HeroTitleStyle}" />
                        <Label Text="{loc:Translate Resource=HomePageResources, Key=Subtitle}"
                               Style="{StaticResource HeroSubtitleStyle}" />
                    </VerticalStackLayout>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Border Grid.Column="0"
                                StrokeThickness="0"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 18"
                                Padding="12,10"
                                BackgroundColor="{DynamicResource AppHeroTileOverlayColor}">
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8">
                                <Label Text="🍽️"
                                       FontSize="16"
                                       VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="0">
                                    <Label Text="{Binding RecipeCount}"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                    <Label Text="{loc:Translate Resource=HomePageResources, Key=SavedRecipes}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{DynamicResource AppHeroMutedTextColor}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                StrokeThickness="0"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 18"
                                Padding="12,10"
                                BackgroundColor="{DynamicResource AppHeroTileOverlayColor}">
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8">
                                <Label Text="📅"
                                       FontSize="16"
                                       VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="0">
                                    <Label Text="{Binding PlanCount}"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                    <Label Text="{loc:Translate Resource=HomePageResources, Key=ActiveLists}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{DynamicResource AppHeroMutedTextColor}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <ActivityIndicator IsVisible="{Binding IsLoading}"
                               IsRunning="{Binding IsLoading}"
                               Color="{DynamicResource Primary}"
                               HorizontalOptions="Center"
                               HeightRequest="56"
                               WidthRequest="56"
                               Margin="0,20,0,12" />

            <VerticalStackLayout IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                                 Spacing="0">

                <Border Style="{StaticResource SectionCardStyle}"
                        Padding="0"
                        StrokeThickness="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOpenProfileClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="5,Auto,*,Auto"
                          ColumnSpacing="12"
                          Padding="0">
                        <BoxView Grid.Column="0"
                                 CornerRadius="3"
                                 Color="{DynamicResource Primary}"
                                 VerticalOptions="Fill" />

                        <Border Grid.Column="1"
                                Margin="14,14,0,14"
                                WidthRequest="46"
                                HeightRequest="46"
                                StrokeThickness="0"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 23"
                                BackgroundColor="{DynamicResource Secondary}">
                            <Label Text="👤"
                                   FontSize="22"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="2"
                                             Padding="0,14"
                                             Spacing="2"
                                             VerticalOptions="Center">
                            <Label Text="{loc:Translate Resource=HomePageResources, Key=Profile}"
                                   Style="{StaticResource SectionTitleStyle}" />
                            <Label Text="{loc:Translate Resource=HomePageResources, Key=ProfileSubtitle}"
                                   Style="{StaticResource SectionSubtitleStyle}" />
                        </VerticalStackLayout>

                        <Border Grid.Column="3"
                                Margin="0,14,14,14"
                                WidthRequest="34"
                                HeightRequest="34"
                                StrokeThickness="0"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="{DynamicResource Secondary}"
                                VerticalOptions="Center">
                            <Label Text="→"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource FrameTextColor}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <HorizontalStackLayout Spacing="8"
                                                   VerticalOptions="Center">
                                <Label Text="📅"
                                       FontSize="20"
                                       VerticalOptions="Center" />
                                <Label Text="{loc:Translate Resource=HomePageResources, Key=PlannedMealsHeader}"
                                       Style="{StaticResource SectionTitleStyle}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <Button Grid.Column="1"
                                    Style="{StaticResource PeriodButtonStyle}"
                                    Text="{Binding PlannedMealsPeriodDisplay}"
                                    Command="{Binding ChangePlannedMealsPeriodCommand}" />
                        </Grid>

                        <Label Text="{loc:Translate Resource=HomePageResources, Key=ClickRecipeHint}"
                               FontSize="12"
                               TextColor="{DynamicResource SecondaryText}" />

                        <Label IsVisible="{Binding HasPlannedMeals, Converter={StaticResource InvertedBoolConverter}}"
                               Text="{loc:Translate Resource=HomePageResources, Key=NoPlannedMealsMessage}"
                               FontSize="12"
                               TextColor="{DynamicResource SecondaryText}" />

                        <ScrollView MaximumHeightRequest="{Binding PlannedMealsMaxHeight}"
                                    VerticalScrollBarVisibility="Never">
                            <CollectionView ItemsSource="{Binding PlannedMealHistory}"
                                            SelectionMode="None"
                                            ItemSizingStrategy="MeasureAllItems">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PlannedMealGroup">
                                        <VerticalStackLayout Spacing="8"
                                                             Margin="0,4,0,10">
                                            <Label Text="{Binding DateLabel}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="{DynamicResource Primary}" />

                                            <CollectionView ItemsSource="{Binding Meals}"
                                                            SelectionMode="None"
                                                            ItemSizingStrategy="MeasureAllItems">
                                                <CollectionView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:PlannedMeal">
                                                        <Border StrokeThickness="0"
                                                                Stroke="Transparent"
                                                                StrokeShape="RoundRectangle 14"
                                                                BackgroundColor="{AppThemeBinding Light=#F7F5FC, Dark={StaticResource Gray700}}"
                                                                Padding="12,10"
                                                                Margin="0,0,0,8">
                                                            <Border.GestureRecognizers>
                                                                <TapGestureRecognizer Command="{Binding Source={x:Reference HomePageView}, Path=BindingContext.ShowMealDetailsPopupCommand}"
                                                                                      CommandParameter="{Binding .}" />
                                                            </Border.GestureRecognizers>
                                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                                  ColumnSpacing="10">
                                                                <Label Text="•"
                                                                       FontSize="18"
                                                                       TextColor="{DynamicResource Primary}"
                                                                       VerticalOptions="Center" />
                                                                <Label Grid.Column="1"
                                                                       Text="{Binding Recipe.Name}"
                                                                       FontSize="15"
                                                                       TextColor="{DynamicResource PrimaryText}"
                                                                       VerticalOptions="Center"
                                                                       LineBreakMode="TailTruncation" />
                                                                <Label Grid.Column="2"
                                                                       Text="{Binding Portions, Converter={StaticResource FormatWithResourceConverter}, ConverterParameter=PortionsFormat}"
                                                                       FontSize="11"
                                                                       TextColor="{DynamicResource SecondaryText}"
                                                                       VerticalOptions="Center" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                            </CollectionView>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </ScrollView>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <HorizontalStackLayout Spacing="8"
                                                   VerticalOptions="Center">
                                <Label Text="📊"
                                       FontSize="20"
                                       VerticalOptions="Center" />
                                <Label Text="{loc:Translate Resource=HomePageResources, Key=NutritionStatsHeader}"
                                       Style="{StaticResource SectionTitleStyle}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <Button Grid.Column="1"
                                    Style="{StaticResource PeriodButtonStyle}"
                                    Text="{Binding NutritionPeriodDisplay}"
                                    Command="{Binding ChangeNutritionPeriodCommand}" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="10"
                              RowSpacing="10">
                            <Border Grid.Row="0"
                                    Grid.ColumnSpan="3"
                                    StrokeThickness="0"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 18"
                                    BackgroundColor="{AppThemeBinding Light=#FFF3EE, Dark=#4A2B1F}"
                                    Padding="14,12">
                                <HorizontalStackLayout Spacing="10"
                                                       VerticalOptions="Center">
                                    <Label Text="🔥"
                                           FontSize="20"
                                           VerticalOptions="Center" />
                                    <VerticalStackLayout Spacing="1">
                                        <Label Text="{loc:Translate Resource=HomePageResources, Key=Calories}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#8E4B28, Dark=#FFBC9A}" />
                                        <Label Text="{Binding CaloriesDisplay, StringFormat='{}{0} kcal'}"
                                               FontSize="24"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#FF6B35, Dark=#FFBC9A}" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </Border>

                            <Border Grid.Row="1"
                                    Grid.Column="0"
                                    StrokeThickness="0"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 16"
                                    BackgroundColor="{AppThemeBinding Light=#EFF6FF, Dark=#1F3550}"
                                    Padding="12,12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="🥩"
                                           FontSize="18" />
                                    <Label Text="{loc:Translate Resource=HomePageResources, Key=Protein}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#4D6582, Dark=#A9CCFF}" />
                                    <Label Text="{Binding ProteinDisplay}"
                                           Style="{StaticResource MacroValueStyle}"
                                           TextColor="{AppThemeBinding Light=#3B82F6, Dark=#A9CCFF}" />
                                    <BoxView HeightRequest="4"
                                             CornerRadius="2"
                                             Color="{AppThemeBinding Light=#3B82F6, Dark=#A9CCFF}"
                                             HorizontalOptions="Fill" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Row="1"
                                    Grid.Column="1"
                                    StrokeThickness="0"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 16"
                                    BackgroundColor="{AppThemeBinding Light=#ECFDF5, Dark=#1D3B2F}"
                                    Padding="12,12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="🌾"
                                           FontSize="18" />
                                    <Label Text="{loc:Translate Resource=HomePageResources, Key=Carbs}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#477A65, Dark=#9DE3C1}" />
                                    <Label Text="{Binding CarbsDisplay}"
                                           Style="{StaticResource MacroValueStyle}"
                                           TextColor="{AppThemeBinding Light=#10B981, Dark=#9DE3C1}" />
                                    <BoxView HeightRequest="4"
                                             CornerRadius="2"
                                             Color="{AppThemeBinding Light=#10B981, Dark=#9DE3C1}"
                                             HorizontalOptions="Fill" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Row="1"
                                    Grid.Column="2"
                                    StrokeThickness="0"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 16"
                                    BackgroundColor="{AppThemeBinding Light=#FFFBEB, Dark=#47391C}"
                                    Padding="12,12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="🧈"
                                           FontSize="18" />
                                    <Label Text="{loc:Translate Resource=HomePageResources, Key=Fats}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#886D1A, Dark=#F6D588}" />
                                    <Label Text="{Binding FatDisplay}"
                                           Style="{StaticResource MacroValueStyle}"
                                           TextColor="{AppThemeBinding Light=#F59E0B, Dark=#F6D588}" />
                                    <BoxView HeightRequest="4"
                                             CornerRadius="2"
                                             Color="{AppThemeBinding Light=#F59E0B, Dark=#F6D588}"
                                             HorizontalOptions="Fill" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Label IsVisible="{Binding HasNutritionData, Converter={StaticResource InvertedBoolConverter}}"
                               Text="{loc:Translate Resource=HomePageResources, Key=NoNutritionData}"
                               FontSize="12"
                               TextColor="{DynamicResource SecondaryText}" />
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,0,0,6">
                    <Border Grid.Column="0"
                            Style="{StaticResource SectionCardStyle}"
                            Padding="14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnArchiveClicked" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="📁"
                                   FontSize="22" />
                            <Label Text="{loc:Translate Resource=HomePageResources, Key=Archive}"
                                   Style="{StaticResource SectionTitleStyle}" />
                            <Label Text="{Binding ArchivedPlanCount, StringFormat='{}{0}'}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource Primary}" />
                            <HorizontalStackLayout Spacing="8"
                                                     VerticalOptions="Center">
                                <Label Text="{loc:Translate Resource=HomePageResources, Key=InArchive}"
                                       Style="{StaticResource SectionSubtitleStyle}" />
                                <Border StrokeThickness="0"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="{DynamicResource Secondary}"
                                        Padding="8,5"
                                        VerticalOptions="Center">
                                    <Label Text="{loc:Translate Resource=HomePageResources, Key=GoToArchive}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{DynamicResource FrameTextColor}" />
                                </Border>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource SectionCardStyle}"
                            Padding="14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSettingsClicked" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="⚙️"
                                   FontSize="22" />
                            <Label Text="{loc:Translate Resource=HomePageResources, Key=Settings}"
                                   Style="{StaticResource SectionTitleStyle}" />
                            <Label Text="🛠️"
                                   FontSize="22"
                                   TextColor="{DynamicResource Primary}" />
                            <HorizontalStackLayout Spacing="8"
                                                     VerticalOptions="Center">
                                <Label Text="{loc:Translate Resource=HomePageResources, Key=Customize}"
                                       Style="{StaticResource SectionSubtitleStyle}" />
                                <Border StrokeThickness="0"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="{DynamicResource Secondary}"
                                        Padding="8,5"
                                        VerticalOptions="Center">
                                    <Label Text="{loc:Translate Resource=HomePageResources, Key=GoToSettings}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{DynamicResource FrameTextColor}" />
                                </Border>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>