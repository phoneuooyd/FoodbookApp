<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:FoodbookApp.Localization"
             xmlns:svc="clr-namespace:Foodbook.Services"
             x:Class="Foodbook.Views.ProfilePage"
             x:Name="RootPage"
             Title="{x:Static loc:ProfilePageResources.Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <ContentPage.Resources>
        <Style x:Key="ProfileCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{DynamicResource ProfileCardSurfaceColor}" />
            <Setter Property="Stroke" Value="{DynamicResource ProfileCardStrokeColor}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeShape" Value="RoundRectangle 18" />
        </Style>

        <Style x:Key="ProfileSectionLabel" TargetType="Label">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="CharacterSpacing" Value="1.2" />
            <Setter Property="TextColor" Value="{DynamicResource ProfileSectionLabelColor}" />
        </Style>
    </ContentPage.Resources>

    <Grid>
        <!-- Main profile view -->
        <Grid x:Name="ProfileMainView" RowDefinitions="Auto,*">
            <Grid x:Name="HeroBar" Grid.Row="0" Background="{DynamicResource AppHeroGradientBrush}" Padding="20,46,20,18">
                <Border WidthRequest="128" HeightRequest="128" HorizontalOptions="End" VerticalOptions="Start" TranslationX="22" TranslationY="-36" BackgroundColor="{DynamicResource AppHeroBubbleColorStrong}" StrokeThickness="0" StrokeShape="RoundRectangle 64" />
                <Border WidthRequest="74" HeightRequest="74" HorizontalOptions="End" VerticalOptions="Start" TranslationX="-2" TranslationY="14" BackgroundColor="{DynamicResource AppHeroBubbleColorMedium}" StrokeThickness="0" StrokeShape="RoundRectangle 37" />

                <VerticalStackLayout Spacing="10" ZIndex="2">
                    <Label Text="{x:Static loc:ProfilePageResources.HeaderTitle}" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource AppHeroHintTextColor}" />

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border WidthRequest="58" HeightRequest="58" BackgroundColor="{DynamicResource AppHeroActionOverlayColor}" StrokeThickness="0" StrokeShape="RoundRectangle 29">
                            <Label Text="👤" FontSize="26" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label x:Name="HeroUserEmailLabel" Text="" FontSize="20" FontAttributes="Bold" TextColor="White" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Border Grid.Column="0" BackgroundColor="{DynamicResource AppHeroTileOverlayColor}" StrokeThickness="0" Padding="8,7" StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="0">
                                <Label x:Name="RecipesCountLabel" Text="0" FontSize="16" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                                <Label Text="{svc:Translate Resource=ProfilePageResources, Key=HeroRecipesCountLabel}" FontSize="10" TextColor="{DynamicResource AppHeroHintTextColor}" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="{DynamicResource AppHeroTileOverlayColor}" StrokeThickness="0" Padding="8,7" StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="0">
                                <Label x:Name="PlansCountLabel" Text="0" FontSize="16" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                                <Label Text="{svc:Translate Resource=ProfilePageResources, Key=HeroPlansCountLabel}" FontSize="10" TextColor="{DynamicResource AppHeroHintTextColor}" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="{DynamicResource AppHeroTileOverlayColor}" StrokeThickness="0" Padding="8,7" StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="0">
                                <Label x:Name="ListsCountLabel" Text="0" FontSize="16" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                                <Label Text="{svc:Translate Resource=ProfilePageResources, Key=HeroListsCountLabel}" FontSize="10" TextColor="{DynamicResource AppHeroHintTextColor}" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Grid>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="16" Spacing="10">
                    <VerticalStackLayout x:Name="AccountContentSection" Spacing="10">
                        <Label Text="{svc:Translate Resource=ProfilePageResources, Key=AccountSettingsSectionLabel}" Style="{StaticResource ProfileSectionLabel}" />

                        <Border Style="{StaticResource ProfileCard}" Background="{DynamicResource ProfilePlanRowBrush}" Stroke="{DynamicResource ProfilePlanRowBorderColor}" Padding="16,14">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOpenPlanDetailsTapped" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                                <Label Text="✨" FontSize="22" VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label x:Name="CurrentPlanNameLabel" Text="" FontSize="16" FontAttributes="Bold" TextColor="White" />
                                    <Label x:Name="CurrentPlanRenewalLabel" Text="" FontSize="12" TextColor="{DynamicResource AppHeroSubtitleTextColor}" />
                                </VerticalStackLayout>
                                <Border Grid.Column="2" BackgroundColor="{DynamicResource ProfilePlanActiveBadgeBackgroundColor}" StrokeThickness="0" Padding="8,4" StrokeShape="RoundRectangle 10" VerticalOptions="Center">
                                    <Label x:Name="CurrentPlanStatusLabel" Text="" FontSize="10" FontAttributes="Bold" TextColor="{DynamicResource ProfilePlanActiveBadgeTextColor}" />
                                </Border>
                                <Label Grid.Column="3" Text="›" FontSize="18" TextColor="{DynamicResource AppHeroHintTextColor}" VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource ProfileCard}" Padding="0">
                            <VerticalStackLayout Spacing="0">
                                <Grid Padding="14,12" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Border WidthRequest="36" HeightRequest="36" BackgroundColor="{DynamicResource SegmentedContainerColor}" StrokeThickness="0" StrokeShape="RoundRectangle 10" VerticalOptions="Center">
                                        <Label Text="👤" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                        <Label Text="{svc:Translate Resource=ProfilePageResources, Key=AccountDataTitle}" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource FrameTextColor}" />
                                        <Label Text="{svc:Translate Resource=ProfilePageResources, Key=AccountDataSubtitle}" FontSize="11" TextColor="{DynamicResource SecondaryText}" />
                                    </VerticalStackLayout>
                                </Grid>
                                <BoxView HeightRequest="1" BackgroundColor="{DynamicResource ProfileCardStrokeColor}" />
                                <Grid Padding="14,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnOpenSyncQueueTapped" />
                                    </Grid.GestureRecognizers>
                                    <Border WidthRequest="36" HeightRequest="36" BackgroundColor="{DynamicResource SegmentedContainerColor}" StrokeThickness="0" StrokeShape="RoundRectangle 10" VerticalOptions="Center">
                                        <Label Text="🔄" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                        <Label Text="{x:Static loc:ProfilePageResources.CloudSyncHeader}" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource FrameTextColor}" />
                                        <Label Text="Supabase" FontSize="11" TextColor="{DynamicResource SecondaryText}" />
                                        <Label x:Name="SyncStatusLabel"
                                               FontSize="10"
                                               TextColor="{DynamicResource SecondaryText}"
                                               IsVisible="False"
                                               LineBreakMode="WordWrap"
                                               MaxLines="2" />
                                    </VerticalStackLayout>
                                    <Switch Grid.Column="2"
                                            x:Name="CloudSyncSwitch"
                                            Toggled="OnCloudSyncToggled"
                                            OnColor="{DynamicResource Primary}"
                                            ThumbColor="White"
                                            VerticalOptions="Center" />
                                 </Grid>
                             </VerticalStackLayout>
                         </Border>
                     </VerticalStackLayout>

                    <Border x:Name="LoginPanel" Style="{StaticResource ProfileCard}" Padding="16">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{x:Static loc:ProfilePageResources.LoginPanelTitle}" FontAttributes="Bold" FontSize="18" TextColor="{DynamicResource Primary}" />

                            <VerticalStackLayout Spacing="5">
                                <Label Text="{x:Static loc:ProfilePageResources.EmailLabel}" FontSize="12" FontAttributes="Bold" />
                                <Border Style="{StaticResource ModernBorder}">
                                    <Entry x:Name="EmailEntry" Style="{StaticResource ModernEntry}" Placeholder="{x:Static loc:ProfilePageResources.EmailPlaceholder}" Keyboard="Email" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="{x:Static loc:ProfilePageResources.PasswordLabel}" FontSize="12" FontAttributes="Bold" />
                                <Border Style="{StaticResource ModernBorder}">
                                    <Entry x:Name="PasswordEntry" Style="{StaticResource ModernEntry}" Placeholder="{x:Static loc:ProfilePageResources.PasswordPlaceholder}" IsPassword="True" />
                                </Border>
                            </VerticalStackLayout>

                            <Label x:Name="StatusLabel" FontSize="12" TextColor="{DynamicResource SecondaryText}" />

                            <Button Text="{x:Static loc:ProfilePageResources.LoginButton}" StyleClass="Primary" Clicked="OnProfileFetchJwtClicked" />
                            <Button Text="{x:Static loc:ProfilePageResources.RegisterButton}" StyleClass="Secondary" Clicked="OnRegisterClicked" />
                        </VerticalStackLayout>
                    </Border>

                    <VerticalStackLayout x:Name="LoggedInPanel" IsVisible="False" Spacing="8">
                        <Button Text="{x:Static loc:ProfilePageResources.LogoutButton}" StyleClass="Primary" Clicked="OnLogoutClicked" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- Plan details view -->
        <Grid x:Name="PlanDetailsView" IsVisible="False" RowDefinitions="Auto,*">
            <Grid Grid.Row="0" Background="{DynamicResource AppHeroGradientBrush}" Padding="16,46,16,16" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Border WidthRequest="34" HeightRequest="34" BackgroundColor="{DynamicResource AppHeroActionOverlayColor}" StrokeThickness="0" StrokeShape="RoundRectangle 17" VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnClosePlanDetailsTapped" />
                    </Border.GestureRecognizers>
                    <Label Text="‹" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="{svc:Translate Resource=ProfilePageResources, Key=SubscriptionHeaderTitle}" FontSize="20" FontAttributes="Bold" TextColor="White" />
                    <Label Text="{svc:Translate Resource=ProfilePageResources, Key=SubscriptionHeaderSubtitle}" FontSize="13" TextColor="{DynamicResource AppHeroSubtitleTextColor}" />
                </VerticalStackLayout>
            </Grid>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="16" Spacing="10">
                    <Label Text="{svc:Translate Resource=ProfilePageResources, Key=CurrentPlanSectionTitle}" Style="{StaticResource ProfileSectionLabel}" />
                    <Border Style="{StaticResource ProfileCard}" Background="{DynamicResource ProfilePlanRowBrush}" Stroke="{DynamicResource ProfilePlanRowBorderColor}" Padding="16">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Label Text="✨" FontSize="24" VerticalOptions="Center" />
                                <Label x:Name="CurrentPlanNameDetailsLabel" Grid.Column="1" Text="" FontSize="20" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
                                <Border Grid.Column="2" BackgroundColor="{DynamicResource ProfilePlanActiveBadgeBackgroundColor}" StrokeThickness="0" Padding="9,4" StrokeShape="RoundRectangle 12" VerticalOptions="Center">
                                    <Label x:Name="CurrentPlanStatusDetailsLabel" Text="" FontSize="10" FontAttributes="Bold" TextColor="{DynamicResource ProfilePlanActiveBadgeTextColor}" />
                                </Border>
                            </Grid>

                            <Label x:Name="CurrentPlanPriceDetailsLabel" Text="" FontSize="24" FontAttributes="Bold" TextColor="White" />

                            <Label x:Name="CurrentPlanFeaturesDetailsLabel"
                                   Text=""
                                   FontSize="12"
                                   TextColor="{DynamicResource AppHeroSubtitleTextColor}"
                                   LineBreakMode="WordWrap" />

                            <Label x:Name="CurrentPlanRenewalDetailsLabel" Text="" FontSize="11" TextColor="{DynamicResource AppHeroHintTextColor}" />
                            <Label x:Name="CurrentPlanLimitsDetailsLabel" Text="" FontSize="11" TextColor="{DynamicResource AppHeroHintTextColor}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border x:Name="PendingSubscriptionCard" Style="{StaticResource ProfileCard}" Padding="16" IsVisible="False">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{x:Static loc:ProfilePageResources.SubscriptionPendingTitle}" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource FrameTextColor}" />
                            <Label x:Name="PendingSubscriptionStatusLabel" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource Primary}" />
                            <Label x:Name="PendingSubscriptionTargetLabel" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                            <Label x:Name="PendingSubscriptionLastAttemptLabel" FontSize="11" TextColor="{DynamicResource SecondaryText}" />
                            <Label x:Name="PendingSubscriptionErrorLabel" FontSize="11" TextColor="#C62828" IsVisible="False" LineBreakMode="WordWrap" />
                            <Button x:Name="ResumeSubscriptionButton"
                                    Text="{x:Static loc:ProfilePageResources.SubscriptionPendingResume}"
                                    Clicked="OnResumePendingSubscriptionClicked"
                                    StyleClass="Primary" />
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="{svc:Translate Resource=ProfilePageResources, Key=OtherPlansSectionTitle}" Style="{StaticResource ProfileSectionLabel}" />

                    <Border Style="{StaticResource ProfileCard}" Padding="16">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <Label Text="🔓" FontSize="18" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{x:Static loc:ProfilePageResources.PlanNameFree}" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" TextColor="{DynamicResource FrameTextColor}" />
                                <Label Grid.Column="2" Text="{svc:Translate Resource=ProfilePageResources, Key=FreePlanPriceLabel}" FontSize="13" TextColor="{DynamicResource SecondaryText}" VerticalOptions="Center" />
                            </Grid>
                            <Label Text="{svc:Translate Resource=ProfilePageResources, Key=FreePlanFeatureRecipes}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                            <Label Text="{svc:Translate Resource=ProfilePageResources, Key=FreePlanFeaturePlanner}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                            <Label Text="{svc:Translate Resource=ProfilePageResources, Key=FreePlanFeatureShoppingList}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                            <Label Text="{svc:Translate Resource=ProfilePageResources, Key=FreePlanFeatureImport}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                            <Button x:Name="SwitchToFreePlanButton"
                                    Text="{svc:Translate Resource=ProfilePageResources, Key=SwitchToFreeButton}"
                                    BackgroundColor="{DynamicResource SegmentedContainerColor}"
                                    TextColor="{DynamicResource SecondaryText}"
                                    BorderColor="{DynamicResource ProfileCardStrokeColor}"
                                    BorderWidth="1" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource ProfileCard}" Padding="16" Stroke="{DynamicResource ProfilePlanRowBorderColor}">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <Label Text="✨" FontSize="18" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{x:Static loc:ProfilePageResources.PlanNamePremiumMonthly}" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" TextColor="{DynamicResource FrameTextColor}" />
                                <Label Grid.Column="2" Text="{svc:Translate Resource=ProfilePageResources, Key=PremiumMonthlyPriceLabel}" FontSize="13" TextColor="{DynamicResource SecondaryText}" VerticalOptions="Center" />
                            </Grid>
                            <Label Text="{svc:Translate Resource=ProfilePageResources, Key=PremiumFeatureAllIncluded}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                            <Label Text="{svc:Translate Resource=ProfilePageResources, Key=PremiumMonthlyFeatureBilling}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                            <Label Text="{svc:Translate Resource=ProfilePageResources, Key=PremiumMonthlyFeatureFlexibility}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                            <Button x:Name="SwitchToMonthlyPlanButton"
                                    Text="{svc:Translate Resource=ProfilePageResources, Key=SwitchToMonthlyButton}"
                                    StyleClass="Primary"
                                    Clicked="OnSwitchToMonthlyClicked" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource ProfileCard}" Padding="16" Stroke="{DynamicResource ProfilePlanRowBorderColor}">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <Label Text="🌟" FontSize="18" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{x:Static loc:ProfilePageResources.PlanNamePremiumYearly}" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" TextColor="{DynamicResource FrameTextColor}" />
                                <Label Grid.Column="2" Text="{svc:Translate Resource=ProfilePageResources, Key=PremiumYearlyPriceLabel}" FontSize="13" TextColor="{DynamicResource SecondaryText}" VerticalOptions="Center" />
                            </Grid>
                            <Label Text="{svc:Translate Resource=ProfilePageResources, Key=PremiumFeatureAllIncluded}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                            <Label Text="{svc:Translate Resource=ProfilePageResources, Key=PremiumYearlyFeatureBilling}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                            <Label Text="{svc:Translate Resource=ProfilePageResources, Key=PremiumYearlyFeatureLowerPrice}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                                <Button x:Name="SwitchToYearlyPlanButton"
                                    Text="{svc:Translate Resource=ProfilePageResources, Key=SwitchToYearlyButton}"
                                    StyleClass="Primary"
                                    Clicked="OnSwitchToYearlyClicked" />
                        </VerticalStackLayout>
                    </Border>

                            <Button x:Name="CancelSubscriptionButton"
                                Text="{svc:Translate Resource=ProfilePageResources, Key=CancelSubscriptionButton}"
                            Clicked="OnCancelSubscriptionClicked"
                            HorizontalOptions="Center"
                            FontSize="12"
                            FontAttributes="Bold"
                            TextColor="#FF5F6D"
                            BackgroundColor="Transparent" />
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- Sync queue details view -->
        <Grid x:Name="SyncQueueDetailsView" IsVisible="False" RowDefinitions="Auto,*">
            <Grid Grid.Row="0" Background="{DynamicResource AppHeroGradientBrush}" Padding="16,46,16,16" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Border WidthRequest="34" HeightRequest="34" BackgroundColor="{DynamicResource AppHeroActionOverlayColor}" StrokeThickness="0" StrokeShape="RoundRectangle 17" VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCloseSyncQueueTapped" />
                    </Border.GestureRecognizers>
                    <Label Text="‹" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="{x:Static loc:ProfilePageResources.SyncQueueTitle}" FontSize="20" FontAttributes="Bold" TextColor="White" />
                    <Label Text="{x:Static loc:ProfilePageResources.SyncQueueSubtitle}" FontSize="13" TextColor="{DynamicResource AppHeroSubtitleTextColor}" />
                </VerticalStackLayout>
            </Grid>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="16" Spacing="10">
                    <Label Text="{x:Static loc:ProfilePageResources.SyncQueueRecentOperations}" Style="{StaticResource ProfileSectionLabel}" />

                    <Border Style="{StaticResource ProfileCard}" Padding="14,12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Label x:Name="SyncQueueSummaryLabel"
                                   Text="{x:Static loc:ProfilePageResources.SyncQueueLoading}"
                                   FontSize="12"
                                   TextColor="{DynamicResource SecondaryText}" />
                            <Button Grid.Column="1"
                                    Text="{x:Static loc:ProfilePageResources.SyncQueueRefresh}"
                                    Clicked="OnRefreshSyncQueueClicked"
                                    FontSize="12"
                                    Padding="10,4"
                                    BackgroundColor="{DynamicResource SegmentedContainerColor}"
                                    TextColor="{DynamicResource FrameTextColor}" />
                        </Grid>
                    </Border>

                    <CollectionView ItemsSource="{Binding Source={x:Reference RootPage}, Path=SyncQueueItems}"
                                    SelectionMode="None"
                                    EmptyView="{x:Static loc:ProfilePageResources.SyncQueueEmpty}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ProfileCard}" Padding="12,10" Margin="0,0,0,8">
                                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4" ColumnSpacing="8">
                                        <Label Text="{Binding Title}" FontSize="13" FontAttributes="Bold" TextColor="{DynamicResource FrameTextColor}" />
                                        <Label Grid.Column="1" Text="{Binding StatusText}" FontSize="12" FontAttributes="Bold" TextColor="{Binding StatusColor}" HorizontalOptions="End" />
                                        <Label Grid.Row="1" Text="{Binding Detail}" FontSize="11" TextColor="{Binding DetailColor}" LineBreakMode="WordWrap" />
                                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding CreatedText}" FontSize="10" TextColor="{DynamicResource SecondaryText}" HorizontalOptions="End" VerticalOptions="Start" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button x:Name="SyncQueueLoadMoreButton"
                            Text="{svc:Translate Resource=ProfilePageResources, Key=SyncQueueLoadMoreButton}"
                            Clicked="OnLoadMoreSyncQueueClicked"
                            IsVisible="False"
                            FontSize="12"
                            Padding="10,6"
                            HorizontalOptions="Center"
                            BackgroundColor="{DynamicResource SegmentedContainerColor}"
                            TextColor="{DynamicResource FrameTextColor}" />
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- Syncing overlay with spinner -->
        <Grid x:Name="SyncingOverlay"
              IsVisible="False"
              BackgroundColor="{AppThemeBinding Light=#80FFFFFF, Dark=#80000000}"
              ZIndex="10">
            <Border HorizontalOptions="Center"
                    VerticalOptions="Center"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="1"
                    Stroke="{DynamicResource ProfileCardStrokeColor}"
                    BackgroundColor="{DynamicResource ProfileCardSurfaceColor}"
                    Padding="32,24">
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <ActivityIndicator x:Name="SyncActivityIndicator"
                                       IsRunning="False"
                                       Color="{DynamicResource Primary}"
                                       WidthRequest="48"
                                       HeightRequest="48"
                                       HorizontalOptions="Center" />
                    <Label x:Name="SyncOverlayLabel"
                           FontSize="14"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           MaximumWidthRequest="220"
                           TextColor="{DynamicResource FrameTextColor}" />
                    <Button x:Name="BackgroundSyncButton"
                            Text="{svc:Translate Resource=ProfilePageResources, Key=BackgroundSyncButton}"
                            StyleClass="Secondary"
                            Clicked="OnBackgroundSyncClicked" />
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
