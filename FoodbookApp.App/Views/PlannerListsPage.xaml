<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Foodbook.Views.PlannerListsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:loc="clr-namespace:Foodbook.Services"
    xmlns:vm="clr-namespace:Foodbook.ViewModels"
    xmlns:models="clr-namespace:Foodbook.Models"
    xmlns:components="clr-namespace:Foodbook.Views.Components"
    xmlns:resources="clr-namespace:FoodbookApp.Localization"
    xmlns:converters="clr-namespace:Foodbook.Converters"
    x:Name="ThisPage"
    x:DataType="vm:PlannerListsViewModel"
    BackgroundColor="{DynamicResource PageBackgroundColor}"
    Shell.NavBarIsVisible="false">

    <ContentPage.Resources>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />

        <LinearGradientBrush x:Key="HeroGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{DynamicResource Primary}" Offset="0.0" />
            <GradientStop Color="{DynamicResource Tertiary}" Offset="1.0" />
        </LinearGradientBrush>

        <Style x:Key="HeroTitleStyle" TargetType="Label">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="White" />
        </Style>

        <!-- Plans tab list row template -->
        <DataTemplate x:Key="PlanRowTemplate" x:DataType="models:Plan">
            <components:UniversalListItemComponent 
                EditCommand="{Binding BindingContext.EditPlanCommand, Source={x:Reference ThisPage}}"
                ArchiveCommand="{Binding BindingContext.ArchivePlanCommand, Source={x:Reference ThisPage}}"
                ShowNutritionLayout="False"
                ShowPlanLayout="True"
                ShowDeleteButton="False"
                ShowArchiveButton="True"
                ShowSubtitle="False" />
        </DataTemplate>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0"
              MinimumHeightRequest="88"
              MaximumHeightRequest="88"
              Padding="20,16,20,14"
              Background="{StaticResource HeroGradientBrush}">
            <Border WidthRequest="104"
                    HeightRequest="104"
                    StrokeThickness="0"
                    Stroke="Transparent"
                    BackgroundColor="#14FFFFFF"
                    StrokeShape="RoundRectangle 52"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    TranslationX="22"
                    TranslationY="-28" />
            <Border WidthRequest="72"
                    HeightRequest="72"
                    StrokeThickness="0"
                    Stroke="Transparent"
                    BackgroundColor="#10FFFFFF"
                    StrokeShape="RoundRectangle 36"
                    HorizontalOptions="Start"
                    VerticalOptions="End"
                    TranslationX="-10"
                    TranslationY="14" />

            <VerticalStackLayout Spacing="0"
                                 VerticalOptions="End"
                                 ZIndex="1">
                <Label Text="{loc:Translate Resource=PlannerListsPageResources, Key=PlannerTitle}"
                       Style="{StaticResource HeroTitleStyle}" />
            </VerticalStackLayout>
        </Grid>

        <components:TabComponent
            Grid.Row="1"
            x:Name="MainTabComponent"
            SelectedIndex="{Binding SelectedTabIndex}">

            <!-- Tab 0: Plans -->
            <components:TabItem
                Name="{loc:Translate Resource=PlannerListsPageResources, Key=PlansTabTitle}">
                <Grid>
                    <components:GenericListComponent
                        x:Name="PlannerList"
                        ItemsSource="{Binding Plans}"
                        ItemTemplate="{StaticResource PlanRowTemplate}"
                        EmptyTitle="{loc:Translate Resource=PlannerListsPageResources, Key=EmptyTitle}"
                        EmptyHint="{loc:Translate Resource=PlannerListsPageResources, Key=EmptyHint}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" />

                    <components:FloatingActionButtonComponent
                        Command="{Binding CreatePlanCommand}"
                        IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                        ButtonText="+"
                        IsExpandable="False" />
                </Grid>
            </components:TabItem>

            <!-- Tab 1: Foodbooks (placeholder until model is implemented) -->
            <components:TabItem
                Name="{loc:Translate Resource=PlannerListsPageResources, Key=FoodbooksTabTitle}">
                <Grid>
                    <StackLayout
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Padding="20"
                        Spacing="8">
                        <Label
                            Text="{loc:Translate Resource=PlannerListsPageResources, Key=FoodbooksEmptyTitle}"
                            FontSize="18"
                            FontAttributes="Bold"
                            HorizontalOptions="Center"
                            TextColor="{DynamicResource FrameTextColor}" />
                        <Label
                            Text="{loc:Translate Resource=PlannerListsPageResources, Key=FoodbooksEmptyHint}"
                            FontSize="14"
                            FontAttributes="Bold"
                            HorizontalOptions="Center"
                            TextColor="{DynamicResource FrameTextColor}" />
                    </StackLayout>

                    <components:FloatingActionButtonComponent
                        IsVisible="True"
                        ButtonText="+"
                        IsExpandable="False" />
                </Grid>
            </components:TabItem>

        </components:TabComponent>

    </Grid>
</ContentPage>
