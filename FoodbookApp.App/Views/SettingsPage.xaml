<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Foodbook.ViewModels"
             xmlns:loc="clr-namespace:Foodbook.Services"
             xmlns:converters="clr-namespace:Foodbook.Converters"
             xmlns:controls="clr-namespace:Foodbook.Views.Components"
             x:Class="Foodbook.Views.SettingsPage"
             x:Name="SettingsPageRoot"
             x:DataType="vm:SettingsViewModel"
             Title="{loc:Translate Resource=SettingsPageResources, Key=Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{DynamicResource PageBackgroundColor}">
    <ContentPage.Resources>
        <converters:IsNotNullOrEmptyConverter x:Key="IsNotNullOrEmptyConverter" />
        <converters:CultureCodeToLocalizedNameConverter x:Key="CultureCodeToLocalizedNameConverter" />
        <converters:AppThemeToLocalizedStringConverter x:Key="AppThemeToLocalizedStringConverter" />
        <converters:AppColorThemeToLocalizedStringConverter x:Key="AppColorThemeToLocalizedStringConverter" />
        <converters:ThemeToColorConverter x:Key="ThemeToColorConverter" />
        <converters:FontFamilyToLocalizedStringConverter x:Key="FontFamilyToLocalizedStringConverter" />
        <converters:FontSizeToLocalizedStringConverter x:Key="FontSizeToLocalizedStringConverter" />
        <converters:BoolToColorConverter x:Key="BoolToColorConverter" />

        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{DynamicResource DashboardCardBackgroundColor}" />
            <Setter Property="Stroke" Value="{DynamicResource DashboardCardStrokeColor}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        </Style>

        <Style x:Key="SettingsSectionLabel" TargetType="Label">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="CharacterSpacing" Value="1.2" />
            <Setter Property="TextColor" Value="{DynamicResource SecondaryText}" />
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
            <Setter Property="TextColor" Value="{DynamicResource ButtonPrimaryText}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="HeightRequest" Value="44" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" Background="{DynamicResource AppHeroGradientBrush}" Padding="20,42,20,14" MinimumHeightRequest="128">
            <Border WidthRequest="108" HeightRequest="108" HorizontalOptions="End" VerticalOptions="Start" TranslationX="20" TranslationY="-34" BackgroundColor="{DynamicResource AppHeroBubbleColorStrong}" StrokeThickness="0" StrokeShape="RoundRectangle 54" />
            <Border WidthRequest="62" HeightRequest="62" HorizontalOptions="End" VerticalOptions="Start" TranslationX="-2" TranslationY="8" BackgroundColor="{DynamicResource AppHeroBubbleColorMedium}" StrokeThickness="0" StrokeShape="RoundRectangle 31" />
            <VerticalStackLayout Spacing="2" ZIndex="2">
                <Label Text="{loc:Translate Resource=SettingsPageResources, Key=HeaderPanelLabel}" FontSize="11" FontAttributes="Bold" TextColor="{DynamicResource AppHeroHintTextColor}" />
                <Label Text="{loc:Translate Resource=SettingsPageResources, Key=Title}" FontSize="24" FontAttributes="Bold" TextColor="White" />
            </VerticalStackLayout>
        </Grid>

        <controls:TabComponent Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" SelectTabCommand="{Binding SelectTabCommand}" TabSize="Small">
            <controls:TabComponent.Tabs>
                <controls:TabItem Name="{loc:Translate Resource=SettingsPageResources, Key=TabLanguage}">
                    <controls:TabItem.Content>
                        <ScrollView>
                            <VerticalStackLayout Padding="16" Spacing="10" BackgroundColor="{DynamicResource PageBackgroundColor}">
                                <Border Style="{StaticResource SettingsCard}">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=LanguageTitle}" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource Primary}" />
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=LanguageDescription}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                                        <Border Style="{StaticResource ModernBorder}" Padding="10,2">
                                            <Picker ItemsSource="{Binding SupportedCultures}" SelectedItem="{Binding SelectedCulture}" ItemDisplayBinding="{Binding ., Converter={StaticResource CultureCodeToLocalizedNameConverter}}" />
                                        </Border>
                                    </VerticalStackLayout>
                                </Border>

                                <Label Text="{loc:Translate Resource=SettingsPageResources, Key=FontFamilyTitle}" Style="{StaticResource SettingsSectionLabel}" />
                                <Border Style="{StaticResource SettingsCard}">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=FontFamilyDescription}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                                        <Border Style="{StaticResource ModernBorder}" Padding="10,2">
                                            <Picker ItemsSource="{Binding SupportedFontFamilies}" SelectedItem="{Binding SelectedFontFamily}" ItemDisplayBinding="{Binding ., Converter={StaticResource FontFamilyToLocalizedStringConverter}}" />
                                        </Border>
                                    </VerticalStackLayout>
                                </Border>

                                <Border Style="{StaticResource SettingsCard}">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=FontSizeTitle}" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource Primary}" />
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=FontSizeDescription}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                                        <Border Style="{StaticResource ModernBorder}" Padding="10,2">
                                            <Picker ItemsSource="{Binding SupportedFontSizes}" SelectedItem="{Binding SelectedFontSize}" ItemDisplayBinding="{Binding ., Converter={StaticResource FontSizeToLocalizedStringConverter}}" />
                                        </Border>
                                    </VerticalStackLayout>
                                </Border>

                                <Border Style="{StaticResource SettingsCard}">
                                    <HorizontalStackLayout Spacing="12">
                                        <Border WidthRequest="44" HeightRequest="44" Background="{DynamicResource AppHeroGradientBrush}" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                                            <Label Text="🍽️" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                            <Label Text="{loc:Translate Resource=SettingsPageResources, Key=VersionInfoTitle}" FontSize="15" FontAttributes="Bold" TextColor="{DynamicResource FrameTextColor}" />
                                            <Label Text="{loc:Translate Resource=SettingsPageResources, Key=VersionNumber}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                                            <Label Text="{loc:Translate Resource=SettingsPageResources, Key=AuthorLabel}" FontSize="11" TextColor="{DynamicResource SecondaryText}" />
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>
                                </Border>
                            </VerticalStackLayout>
                        </ScrollView>
                    </controls:TabItem.Content>
                </controls:TabItem>

                <controls:TabItem Name="{loc:Translate Resource=SettingsPageResources, Key=TabAppearance}">
                    <controls:TabItem.Content>
                        <ScrollView>
                            <VerticalStackLayout Padding="16" Spacing="10" BackgroundColor="{DynamicResource PageBackgroundColor}">
                                <Border Style="{StaticResource SettingsCard}">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=ThemeTitle}" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource Primary}" />
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=ThemeDescription}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                                        <controls:SegmentedPickerComponent
                                            Option1Text="{loc:Translate Resource=SetupWizardPageResources, Key=DarkModeOption}"
                                            Option1Command="{Binding SelectDarkThemeCommand}"
                                            IsOption1Selected="{Binding IsDarkThemeSelected}"
                                            Option2Text="{loc:Translate Resource=SetupWizardPageResources, Key=LightModeOption}"
                                            Option2Command="{Binding SelectLightThemeCommand}"
                                            IsOption2Selected="{Binding IsLightThemeSelected}"
                                            Option3Text="{loc:Translate Resource=SettingsPageResources, Key=ThemeSystem}"
                                            Option3Command="{Binding SelectSystemThemeCommand}"
                                            IsOption3Selected="{Binding IsSystemThemeSelected}"
                                            ShowOption3="True" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Style="{StaticResource SettingsCard}">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=ColorThemeTitle}" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource Primary}" />
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=ColorThemeDescription}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                                        <Border Style="{StaticResource ModernBorder}" Padding="10,2">
                                            <Picker ItemsSource="{Binding SupportedColorThemes}" SelectedItem="{Binding SelectedColorTheme}" ItemDisplayBinding="{Binding ., Converter={StaticResource AppColorThemeToLocalizedStringConverter}}" />
                                        </Border>

                                        <Border Style="{StaticResource SettingsCard}" Padding="0" Margin="0,2,0,0">
                                            <VerticalStackLayout Spacing="0">
                                                <Grid Padding="14,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                    <Border WidthRequest="38" HeightRequest="38" BackgroundColor="{DynamicResource SegmentedContainerColor}" StrokeThickness="0" StrokeShape="RoundRectangle 10" VerticalOptions="Center">
                                                        <Label Text="🖼️" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                                                    </Border>
                                                    <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=WallpaperBackgroundOption}" FontSize="15" FontAttributes="Bold" TextColor="{DynamicResource FrameTextColor}" />
                                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=WallpaperBackgroundDescription}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                                                    </VerticalStackLayout>
                                                    <Switch Grid.Column="2"
                                                            VerticalOptions="Center"
                                                            IsToggled="{Binding IsWallpaperBackgroundEnabled}"
                                                            IsEnabled="{Binding CanUseWallpaperBackground}"
                                                            OnColor="{DynamicResource Primary}" />
                                                </Grid>

                                                <BoxView HeightRequest="1" BackgroundColor="{DynamicResource DashboardCardStrokeColor}" />

                                                <Grid Padding="14,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                    <Border WidthRequest="38" HeightRequest="38" BackgroundColor="{DynamicResource SegmentedContainerColor}" StrokeThickness="0" StrokeShape="RoundRectangle 10" VerticalOptions="Center">
                                                        <Label Text="✨" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                                                    </Border>
                                                    <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=ColorfulBackgroundOption}" FontSize="15" FontAttributes="Bold" TextColor="{DynamicResource FrameTextColor}" />
                                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=ColorfulBackgroundDescription}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                                                    </VerticalStackLayout>
                                                    <Switch Grid.Column="2"
                                                            VerticalOptions="Center"
                                                            IsToggled="{Binding IsColorfulBackgroundEnabled}"
                                                            OnColor="{DynamicResource Primary}" />
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Border>

                                        <Grid HeightRequest="38" ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="10" HorizontalOptions="Center">
                                            <Ellipse Grid.Column="0" Fill="{Binding SelectedColorTheme, Converter={StaticResource ThemeToColorConverter}, ConverterParameter=Primary}" WidthRequest="30" HeightRequest="30" />
                                            <Ellipse Grid.Column="1" Fill="{Binding SelectedColorTheme, Converter={StaticResource ThemeToColorConverter}, ConverterParameter=Secondary}" WidthRequest="30" HeightRequest="30" />
                                            <Ellipse Grid.Column="2" Fill="{Binding SelectedColorTheme, Converter={StaticResource ThemeToColorConverter}, ConverterParameter=Tertiary}" WidthRequest="30" HeightRequest="30" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>
                        </ScrollView>
                    </controls:TabItem.Content>
                </controls:TabItem>

                <controls:TabItem Name="{loc:Translate Resource=SettingsPageResources, Key=TabData}">
                    <controls:TabItem.Content>
                        <ScrollView>
                            <VerticalStackLayout Padding="16" Spacing="10" BackgroundColor="{DynamicResource PageBackgroundColor}">
                                <Border Style="{StaticResource SettingsCard}">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=UpdateIngredientsTitle}" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource Primary}" />
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=UpdateIngredientsDescription}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                                        <Button Text="{loc:Translate Resource=SettingsPageResources, Key=UpdateIngredientsButton}" Clicked="OnUpdateIngredientsClicked" Style="{StaticResource PrimaryActionButton}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Style="{StaticResource SettingsCard}" IsVisible="{Binding Source={x:Reference SettingsPageRoot}, Path=IsDiagnosticMode}">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=DeduplicateIngredientsTitle}" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource Primary}" />
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=DeduplicateIngredientsDescription}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                                        <Button Text="{loc:Translate Resource=SettingsPageResources, Key=DeduplicateIngredientsButton}" Command="{Binding DeduplicateIngredientsCommand}" IsEnabled="{Binding CanExecuteMigration}" Style="{StaticResource PrimaryActionButton}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Style="{StaticResource SettingsCard}">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=DataExportTitle}" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource Primary}" />
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=DataExportDescription}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                                        <Button Text="{loc:Translate Resource=SettingsPageResources, Key=DataExportButton}" Clicked="OnOpenArchivizationClicked" Style="{StaticResource PrimaryActionButton}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Style="{StaticResource SettingsCard}" IsVisible="{Binding Source={x:Reference SettingsPageRoot}, Path=IsDiagnosticMode}">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=DatabaseMigrationTitle}" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource Primary}" />
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=DatabaseMigrationDescription}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                                        <Button Text="{loc:Translate Resource=SettingsPageResources, Key=DatabaseMigrationButton}" Command="{Binding MigrateDatabaseCommand}" IsEnabled="{Binding CanExecuteMigration}" Style="{StaticResource PrimaryActionButton}" />
                                        <Label Text="{Binding MigrationStatus}" IsVisible="{Binding MigrationStatus, Converter={StaticResource IsNotNullOrEmptyConverter}}" FontSize="12" HorizontalTextAlignment="Center" TextColor="{DynamicResource Primary}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Style="{StaticResource SettingsCard}" Stroke="{AppThemeBinding Light=#44DC3545, Dark=#66C62D3A}">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=FactoryResetTitle}" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#DC3545, Dark=#FF8080}" />
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=FactoryResetDescription}" FontSize="12" TextColor="{DynamicResource SecondaryText}" />
                                        <Button Text="{loc:Translate Resource=SettingsPageResources, Key=FactoryResetButton}" Command="{Binding FactoryResetCommand}" IsEnabled="{Binding CanExecuteMigration}" BackgroundColor="{AppThemeBinding Light=#DC3545, Dark=#C62D3A}" TextColor="White" CornerRadius="12" HeightRequest="44" FontAttributes="Bold" />
                                        <Label Text="{loc:Translate Resource=SettingsPageResources, Key=FactoryResetWarning}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light=#DC3545, Dark=#FF8080}" FontAttributes="Bold" />
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>
                        </ScrollView>
                    </controls:TabItem.Content>
                </controls:TabItem>
            </controls:TabComponent.Tabs>
        </controls:TabComponent>
    </Grid>
</ContentPage>
